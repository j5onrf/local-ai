#!/usr/bin/env bash
# AI Project Workspace Initializer v0.7.8
# High-speed, non-interactive project stream formatting for LLM context injection.

set -euo pipefail

TARGET_DIR="${1:-}"
SKILL_NAME="${2:-}" # Captures the skill name from the positional argument

if [ -z "$TARGET_DIR" ]; then
    TARGET_DIR=$(pwd)
fi

TARGET_DIR="${TARGET_DIR/#\~/$HOME}"

if [ ! -d "$TARGET_DIR" ]; then
    echo "⚠️ ERROR: Target workspace directory not found: $TARGET_DIR" >&2
    exit 1
fi

TARGET_DIR=$(cd "$TARGET_DIR" && pwd)
PROJECT_NAME=$(basename "$TARGET_DIR")

# Setup clean projects/ subdirectory
CONTEXT_DIR="/home/j5/.config/local-ai/local-ai-agent/projects"
mkdir -p "$CONTEXT_DIR"

# Generate a unique, path-based safe filename
SAFE_NAME="${TARGET_DIR//\//-}"
SAFE_NAME="${SAFE_NAME#-}"
CONTEXT_OUT="$CONTEXT_DIR/${SAFE_NAME}.txt"

{
    echo "=== ACTIVE PROJECT WORKSPACE ==="
    echo "[INSTRUCTIONS FOR AI]:"
    echo "1. Act directly as a local development agent and copilot embedded in this workspace."
    echo "2. Focus entirely on providing code solutions, refactoring, and directory tasks tailored strictly to this structure."
    echo "3. Prioritize clean, minimal snippets using the file names and architectural layouts found below."
    echo "4. DO NOT provide generic programming advice or basic boilerplate unless explicitly asked."
    
    # Check if a custom skill context is requested and exists
    if [ -n "$SKILL_NAME" ]; then
        # Removed "local" keyword to comply with POSIX standalone script standards
        skill_file="/home/j5/.config/local-ai/local-ai-agent/tools/skills/${SKILL_NAME}.txt"
        if [ -f "$skill_file" ]; then
            echo ""
            echo "[ACTIVE SKILL CONTEXT: ${SKILL_NAME}]"
            cat "$skill_file"
        else
            echo ""
            echo "[WARNING: Requested skill context '${SKILL_NAME}' not found at $skill_file]" >&2
        fi
    fi
    
    echo "--------------------------------"
    echo "[WORKSPACE_INFO] Project: $PROJECT_NAME | Path: $TARGET_DIR"
    echo "--------------------------------"
    echo "[WORKSPACE_FILE_TREE]"
    
    if cd "$TARGET_DIR" 2>/dev/null; then
        find . -maxdepth 3 -not -path '*/.*' | sed 's|^\./||' | sort | sed 's/^/  - /'
    else
        echo "  - Error: Unable to read directory tree paths."
    fi
    echo "--------------------------------"
    echo "[CONTEXT_STATUS] Environment successfully loaded. Awaiting user commands."
} > "$CONTEXT_OUT"

echo -e "\033[1;32mProject '$PROJECT_NAME' indexed successfully.\033[0m"
