#!/usr/bin/env python3
# skeleton-map [Local Map Compiler]

import os
import ast
import json

# Saves the compiled skeleton.json strictly alongside this script file
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
OUTPUT_FILE = os.path.join(SCRIPT_DIR, "skeleton.json")

def analyze_python_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            tree = ast.parse(f.read())
        functions = [node.name for node in ast.walk(tree) if isinstance(node, ast.FunctionDef)]
        classes = [node.name for node in ast.walk(tree) if isinstance(node, ast.ClassDef)]
        return {"type": "python", "classes": classes, "functions": functions}
    except Exception:
        return {"type": "python", "error": "Unparseable"}

def analyze_markdown_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8') as f:
            first_line = f.readline().strip()
        purpose = first_line.lstrip('#').strip() if first_line.startswith('#') else "Agent Documentation Module"
        return {"type": "markdown", "summary": purpose}
    except Exception:
        return {"type": "markdown", "error": "Unreadable"}

def generate_skeleton(target_dir):
    skeleton = {}
    for root, _, files in os.walk(target_dir):
        # Portable exclusion filters for common repository clutter
        if any(ignored in root for ignored in ['.git', '__pycache__', 'logs', '.auto-f', 'node_modules', 'venv']):
            continue
            
        for file in files:
            filepath = os.path.join(root, file)
            rel_path = os.path.relpath(filepath, target_dir)
            
            if file.endswith('.py'):
                skeleton[rel_path] = analyze_python_file(filepath)
            elif file.endswith('.md'):
                skeleton[rel_path] = analyze_markdown_file(filepath)
                
    return skeleton

def main():
    try:
        user_input = input("Target directory (Press Enter for current directory): ").strip()
    except (KeyboardInterrupt, EOFError):
        print("\n✕ Operation cancelled.")
        return

    # Dynamic fallback to current terminal working directory
    if not user_input:
        target_dir = os.getcwd()
    else:
        target_dir = os.path.abspath(os.path.expanduser(user_input))

    if not os.path.isdir(target_dir):
        print(f"❌ Error: '{target_dir}' is not a valid directory.")
        return

    skeleton = generate_skeleton(target_dir)
    
    with open(OUTPUT_FILE, 'w', encoding='utf-8') as f:
        json.dump(skeleton, f, indent=2)
        
    print("✔ Skeleton map compiled successfully.")

if __name__ == "__main__":
    main()
