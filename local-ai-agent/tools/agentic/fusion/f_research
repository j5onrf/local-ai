DRACO_JUDGE_TEMPLATE = """You are the Gemini Draco Judge. Your task is to synthesize raw, diverse reports from a panel of specialist models into a single, cohesive, authoritative solution.

### ORIGINAL USER QUERY:
{user_prompt}

### SPECIALIST INPUTS (PARALLEL RUNS):
{specialist_reports}

---

### SYNTHESIS INSTRUCTIONS:
Consolidate these parallel drafts into a production-ready, definitive response. Align your evaluation with the Draco Deep Research criteria:

1. **Factual Accuracy (Weight: 50%):** Verify all factual assertions. Cross-reference claims between reports. Filter out any logical inconsistencies, unverified assumptions, or potential hallucinations.
2. **Breadth & Depth / Trade-offs (Weight: 25%):** Analyze conflicting advice. Synthesize contrasting technical options or trade-offs into a single, actionable architectural recommendation.
3. **Presentation & Cleanliness (Weight: 15%):** Remove conversational filler, preambles, postambles, and duplicate summaries. Output a highly organized, structurally polished Markdown response.
4. **Citation & Technical Integrity (Weight: 10%):** Keep precise technical names, configuration parameters, and primary code structures intact. Do not simplify away crucial implementation details.

Generate only the final, synthesized answer without explaining your evaluation steps.
"""

class InlineLoader:
    def __init__(self, msg):
        self.msg = msg
        self.active = False
        self.thread = None
        self.chars = ["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"]
        
    def _spin(self):
        idx = 0
        while self.active:
            sys.stderr.write(f"\r\033[1;36m{self.chars[idx % 10]}\033[0m {self.msg}...")
            sys.stderr.flush()
            idx += 1
            time.sleep(0.08)
            
    def start(self):
        self.active = True
        self.thread = threading.Thread(target=self._spin, daemon=True)
        self.thread.start()
        
    def stop(self, success=True):
        self.active = False
        if self.thread:
            self.thread.join()
        status = "\033[1;32m✓\033[0m" if success else "\033[1;31m✗\033[0m"
        sys.stderr.write(f"\r{status} {self.msg}\n")
        sys.stderr.flush()


def query_model(url, headers, model_name, temp, prompt, retries=2):
    """Hits OpenRouter with custom temperatures for Self-Fusion path diversity."""
    payload = {
        "model": model_name,
        "temperature": temp,
        "messages": [{"role": "user", "content": prompt}]
    }
    req = urlreq.Request(url, data=json.dumps(payload).encode("utf-8"), headers=headers, method="POST")
    
    for attempt in range(retries + 1):
        try:
            with urlreq.urlopen(req, timeout=45) as response:
                data = json.loads(response.read().decode("utf-8"))
                if "choices" in data and len(data["choices"]) > 0:
                    return data["choices"][0]["message"]["content"]
                elif "error" in data:
                    err_msg = data["error"].get("message", "API Error")
                    if "rate limit" in err_msg.lower() and attempt < retries:
                        time.sleep(2.0 * (attempt + 1))
                        continue
                    return f"[API ERROR] {model_name}: {err_msg}"
        except urlerr.HTTPError as e:
            if e.code == 429 and attempt < retries:
                time.sleep(2.0 * (attempt + 1))
                continue
            return f"[HTTP ERROR {e.code}] {model_name}"
        except Exception as e:
            if attempt < retries:
                time.sleep(2.0 * (attempt + 1))
                continue
            return f"[CONNECTION ERROR] {model_name}: {e}"
    return f"[ERROR] {model_name} failed after retries."


def execute_synthesis(prompt, reports_markdown):
    """Executes Draco-aligned synthesis using local Gemini API key or fallback."""
    judge_prompt = DRACO_JUDGE_TEMPLATE.format(
        user_prompt=prompt,
        specialist_reports=reports_markdown
    )
    
    gemini_key = os.environ.get("GEMINI_API_KEY")
    openrouter_key = os.environ.get("OPENROUTER_API_KEY")
    
    if gemini_key:
        url = "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions"
        headers = {"Content-Type": "application/json", "Authorization": f"Bearer {gemini_key}"}
        model = os.environ.get("GEMINI_MODEL", "gemini-2.5-flash") # Use highly efficient 2026 Flash model
        sys.stderr.write(f"\033[90m[sys] Synthesizing via local Gemini API ({model})...\033[0m\n")
        return query_model(url, headers, model, 0.1, judge_prompt)
    elif openrouter_key:
        url = "https://openrouter.ai/api/v1/chat/completions"
        headers = {
            "Content-Type": "application/json",
            "Authorization": f"Bearer {openrouter_key}",
            "HTTP-Referer": "https://github.com/j5onrf/ai-suggestion"
        }
        model = os.environ.get("GEMINI_MODEL", "google/gemini-2.5-flash:free")
        sys.stderr.write(f"\033[90m[sys] GEMINI_API_KEY missing. Routing synthesis to OpenRouter ({model})...\033[0m\n")
        return query_model(url, headers, model, 0.1, judge_prompt)
    else:
        return "[SYSTEM ERROR] Synthesis aborted. Configure GEMINI_API_KEY or OPENROUTER_API_KEY."


def run_research_engine(mode, prompt):
    if mode not in FREE_PANELS:
        sys.stderr.write(f"\033[1;31mError: Mode '{mode}' not found. Select 'coder' or 'research'.\033[0m\n")
        sys.exit(1)
        
    openrouter_key = os.environ.get("OPENROUTER_API_KEY")
    if not openrouter_key:
        sys.stderr.write("\033[1;31mError: OPENROUTER_API_KEY not configured.\033[0m\n")
        sys.exit(1)
        
    panel = FREE_PANELS[mode]
    headers = {
        "Content-Type": "application/json",
        "Authorization": f"Bearer {openrouter_key}",
        "HTTP-Referer": "https://github.com/j5onrf/ai-suggestion"
    }
    url = "https://openrouter.ai/api/v1/chat/completions"
    
    sys.stderr.write(f"\033[1;34m⚡ Launching Fusion-Research [{mode.upper()} Mode]\033[0m\n")
    sys.stderr.write(f"\033[90mObjective: {prompt}\033[0m\n\n")
    
    # 1. Parallel Specialists Dispatch (with Self-Fusion)
    loader = InlineLoader(f"Dispatching {len(panel)} parallel models (including Self-Fusion paths)")
    loader.start()
    
    results = {}
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(panel)) as executor:
        futures = {
            executor.submit(query_model, url, headers, model, temp, prompt): (model, temp)
            for model, temp in panel
        }
        for future in concurrent.futures.as_completed(futures):
            model, temp = futures[future]
            try:
                results[f"{model} (Temp: {temp})"] = future.result()
            except Exception as exc:
                results[f"{model} (Temp: {temp})"] = f"[EXCEPTION] {exc}"
                
    loader.stop()
    
    # 2. Write Local Audit Log
    log_loader = InlineLoader("Compiling results to audit log")
    log_loader.start()
    
    reports_markdown = []
    for identifier, content in results.items():
        reports_markdown.append(f"### Specialist: {identifier}\n\n````\n{content}\n````\n")
    all_reports = "\n".join(reports_markdown)
    
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    log_filepath = os.path.join(LOGS_DIR, f"fusion_research_{mode}_{timestamp}.md")
    
    log_content = f"""# Fusion-Research Audit Log
- **Mode:** {mode}
- **Timestamp:** {time.strftime('%Y-%m-%d %H:%M:%S')}
- **Objective:** {prompt}

---

## Specialist Reports

{all_reports}
"""
    try:
        with open(log_filepath, "w", encoding="utf-8") as f:
            f.write(log_content)
        log_loader.stop()
        sys.stderr.write(f"\033[90mPreserved raw panels at: {log_filepath}\033[0m\n\n")
    except Exception as e:
        log_loader.stop(success=False)
        sys.stderr.write(f"\033[1;31mLogging write failed: {e}\033[0m\n\n")
        
    # 3. Perform Draco Synthesis
    synthesis_loader = InlineLoader("Synthesizing outputs with Gemini Draco Judge")
    synthesis_loader.start()
    
    final_output = execute_synthesis(prompt, all_reports)
    
    if final_output and not final_output.startswith("[SYSTEM ERROR]"):
        synthesis_loader.stop()
    else:
        synthesis_loader.stop(success=False)
        
    return final_output


if __name__ == "__main__":
    import argparse
    parser = argparse.ArgumentParser(description="Fusion-Research CLI Agent")
    parser.add_argument("--mode", choices=["coder", "research"], required=True)
    parser.add_argument("prompt")
    
    args = parser.parse_args()
    print(run_research_engine(args.mode, args.prompt))
