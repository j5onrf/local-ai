        ("openai/gpt-oss-120b:free", 0.8),            # Self-Fusion run (high temp path diversity) [03:06]
        ("deepseek/deepseek-r1:free", 0.3),           # Deep Chain-of-Thought
        ("nvidia/nemotron-3-super:free", 0.5)         # 1M context MoE orchestration
    ]
