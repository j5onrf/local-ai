FREE_PANELS = {
    "coder": [
        ("poolside/laguna-m.1:free", 0.1),            # Flagship coding agent [1.1.4]
        ("qwen/qwen3-coder:free", 0.2),               # State-of-the-art free coding
        ("openai/gpt-oss-120b:free", 0.7)             # High-reasoning open model
    ],
    "research": [
