#!/usr/bin/env bash
# ai-commit - Automate Git Commits with AI Context v1.0.4

set -euo pipefail

# Check if there are any staged changes
if [[ -z "$(git diff --cached)" ]]; then
    echo "❌ Error: No staged changes found. Run 'git add' first." >&2
    exit 1
fi

# Define paths to bypass interactive subshell function limits
_AI_SCRIPT_PATH="$HOME/.config/local-ai/local-ai-agent/alias-ai.py"
_AI_PYTHON_BIN=$(command -v python3 2>/dev/null || type -p python3 2>/dev/null || echo "python3")

# Query the Python script directly to generate a highly simplified, imperative message
message=$("$_AI_PYTHON_BIN" "$_AI_SCRIPT_PATH" --talk "Write a highly concise, imperative git commit message (max 6-8 words) describing these staged changes. Start with an action verb (e.g. Update, Fix, Add, Refactor) and omit redundant words like 'AI Suggestion' or 'local-ai': $(git diff --cached)")

# Clean up any trailing quotes or spaces
message=$(echo "$message" | tr -d '"' | xargs)

echo -e "\nAI-Commit (Edit inline with arrows/backspace, then press Enter):"

# Pre-fill the terminal prompt with the AI suggestion for direct editing
read -e -i "$message" -p "Commit message: " user_message

# Abort if the user completely cleared out the message
if [[ -z "$user_message" ]]; then
    echo "❌ Error: Commit message cannot be empty. Aborting." >&2
    exit 1
fi

# Execute the commit with the final text
git commit -m "$user_message"
