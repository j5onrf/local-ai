#!/usr/bin/env bash
# ai-status - Diagnostics for Local-AI Agent Stack v1.0.0

set -euo pipefail

# Helper to mask API keys safely
mask_key() {
    local key="${1:-}"
    if [[ -z "$key" ]]; then
        echo "*Not Exported*"
    else
        echo "Enabled (\`${key:0:6}...${key: -4}\`)"
    fi
}

# Helper to check endpoint connectivity
check_online() {
    local url="$1"
    if curl -s -I --connect-timeout 1.5 "$url" >/dev/null; then
        echo "**Online**"
    else
        echo "*Offline / Unreachable*"
    fi
}

echo "# ACTIVE AI ROUTING DIAGNOSTICS"
echo ""
echo "> **Instructions for AI:**"
echo "> 1. Inform the user which AI provider is currently active and which model is selected."
echo "> 2. If a key is disabled or an endpoint is offline (forcing a fallback to OpenRouter or Local), clearly explain why the current provider was chosen."
echo "> 3. Keep your explanation to 2 sentences max."
echo "> 4. Format your output strictly for clean, plain-text terminal rendering. DO NOT use any Markdown formatting in your response."
echo ""
echo "---"
echo ""
echo "## CREDENTIALS & CONFIGURATION"
echo "* **GEMINI_API_KEY**  : $(mask_key "${GEMINI_API_KEY:-}")"
echo "* **CLOUD_MODEL**     : \`${CLOUD_MODEL:-gemini-3.1-flash-lite}\`"
echo ""
echo "* **OPENROUTER_KEY**  : $(mask_key "${OPENROUTER_API_KEY:-}")"
echo "* **OPENROUTER_MODEL**: \`${OPENROUTER_MODEL:-poolside/laguna-m.1:free}\`"
echo ""
echo "---"
echo ""
echo "## ENDPOINT STATUS"

# Evaluate connections
gemini_conn=1
if [[ -n "${GEMINI_API_KEY:-}" ]]; then
    if curl -s -I --connect-timeout 1.5 "https://generativelanguage.googleapis.com" >/dev/null; then
        gemini_conn=0
    fi
fi

or_conn=1
if [[ -n "${OPENROUTER_API_KEY:-}" ]]; then
    if curl -s -I --connect-timeout 1.5 "https://openrouter.ai" >/dev/null; then
        or_conn=0
    fi
fi

local_conn=1
if curl -s -I --connect-timeout 1.0 "http://localhost:8080" >/dev/null; then
    local_conn=0
fi

# Print Status
if [[ -n "${GEMINI_API_KEY:-}" ]]; then
    echo "* **Google APIs**   : $([[ $gemini_conn -eq 0 ]] && echo "**Online**" || echo "*Offline*")"
else
    echo "* **Google APIs**   : *Skipped (No Key)*"
fi

if [[ -n "${OPENROUTER_API_KEY:-}" ]]; then
    echo "* **OpenRouter API** : $([[ $or_conn -eq 0 ]] && echo "**Online**" || echo "*Offline*")"
else
    echo "* **OpenRouter API** : *Skipped (No Key)*"
fi

echo "* **Local Server**   : $([[ $local_conn -eq 0 ]] && echo "**Online**" || echo "*Offline*")"
echo ""
echo "---"
echo ""
echo "## ACTIVE RUNTIME ROUTE"

if [[ -n "${GEMINI_API_KEY:-}" && $gemini_conn -eq 0 ]]; then
    echo "* **Selected Provider**: **Gemini Cloud API**"
    echo "* **Active Model**     : \`${CLOUD_MODEL:-gemini-3.1-flash-lite}\`"
elif [[ -n "${OPENROUTER_API_KEY:-}" && $or_conn -eq 0 ]]; then
    echo "* **Selected Provider**: **OpenRouter API**"
    echo "* **Active Model**     : \`${OPENROUTER_MODEL:-poolside/laguna-m.1:free}\`"
elif [[ $local_conn -eq 0 ]]; then
    echo "* **Selected Provider**: **Local AI Server**"
    echo "* **Active Model**     : \`Local Server\`"
else
    echo "* **Selected Provider**: *None / All Offline*"
fi
