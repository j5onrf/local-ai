#!/usr/bin/env python3
# follow-up - Standalone Agentic Brainstorm Engine v1.5.3
# Path: ~/.config/local-ai/local-ai-agent/tools/follow-up

import sys, os, json, re, urllib.request as urlreq

CFG_DIR = os.path.expanduser("~/.config/local-ai/local-ai-agent")
THINK_FILE = f"{CFG_DIR}/skills/meta/follow-up.md"

# 1. Read serialized history from stdin
try:
    history = json.loads(sys.stdin.read())
except Exception:
    sys.stderr.write("Error: No valid chat history passed to think tool.\n")
    sys.exit(1)

# 2. Extract dynamic option count from CLI arguments
option_count = 3
if len(sys.argv) > 1:
    match = re.search(r'(?:/f|f)\s+(\d+)', " ".join(sys.argv[1:]).lower())
    if match:
        parsed_val = int(match.group(1))
        if 1 <= parsed_val <= 10:
            option_count = parsed_val

# 3. Read or generate the structured system prompt
prompt = ""
if os.path.exists(THINK_FILE):
    try:
        with open(THINK_FILE) as f:
            prompt = f.read().strip()
    except Exception:
        pass

# Zero-config fallback with rigid constraints (Using Follow-ups: header)
if not prompt:
    prompt = (
        "Analyze history and output exactly 3 next-step follow-up questions or commands.\n"
        "Each option must be strictly 6 to 9 words long. Do not use conversational filler.\n"
        "Do not use markdown. Output exactly this format:\n\n"
        "Follow-ups\n"
        "[Option 1]\n"
        "[Option 2]\n"
        "[Option 3]"
    )
else:
    # Dynamically inject the requested option count into the markdown template
    prompt = prompt.replace("exactly 3", f"exactly {option_count}")

# 4. Append the dynamic think system prompt to the temporary history
history.append({"role": "system", "content": prompt})

# 5. First-turn Safeguard: Ensure at least one user-role message is present on the stack to prevent API 400 Errors
has_user_turn = any(msg.get("role") == "user" for msg in history)
if not has_user_turn:
    history.append({"role": "user", "content": "Generate triggers."})

# 6. Stream LLM Response via active fallbacks
configs = []
gkey, okey = os.environ.get("GEMINI_API_KEY"), os.environ.get("OPENROUTER_API_KEY")
if gkey:
    configs.append(("https://generativelanguage.googleapis.com/v1beta/openai/chat/completions", {"Content-Type": "application/json", "Authorization": f"Bearer {gkey}"}, os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite"), {}))
if okey:
    m = os.environ.get("OPENROUTER_MODEL", "poolside/laguna-m.1:free")
    configs.append(("https://openrouter.ai/api/v1/chat/completions", {"Content-Type": "application/json", "Authorization": f"Bearer {okey}", "HTTP-Referer": "https://github.com/j5onrf/ai-suggestion"}, m, {"models": [m, "qwen/qwen3-coder:free", "openrouter/free"]}))
configs.append(("http://localhost:8080/v1/chat/completions", {"Content-Type": "application/json"}, None, {}))

for url, headers, model, extra in configs:
    body = {"messages": history, "stream": True, **extra}
    if model: body["model"] = model
    req = urlreq.Request(url, data=json.dumps(body).encode("utf-8"), headers=headers, method="POST")
    try:
        with urlreq.urlopen(req, timeout=10) as response:
            first_token = True
            chunks = []
            for line in response:
                dec = line.decode("utf-8").strip()
                if not dec: continue
                if dec.startswith("data:"): dec = dec[5:].strip()
                if dec == "[DONE]": continue
                try:
                    data = json.loads(dec)
                    content = ""
                    if "choices" in data and data["choices"]:
                        content = data["choices"][0].get("delta", {}).get("content", "")
                    elif "candidates" in data and data["candidates"]:
                        content = data["candidates"][0].get("content", {}).get("parts", [{}])[0].get("text", "")
                    if content:
                        if first_token:
                            content = content.lstrip()
                            if not content: continue
                            first_token = False
                        
                        # Accumulate stream chunks to process the layout dynamically at the end
                        chunks.append(content)
                except Exception:
                    pass
            
            # 7. Safe In-Memory Post-Processing
            full_text = "".join(chunks).strip()
            
            # Deterministically convert the very last T-junction (├──) to an elbow (└──)
            if "├──" in full_text:
                last_idx = full_text.rfind("├──")
                if last_idx != -1:
                    full_text = full_text[:last_idx] + "└──" + full_text[last_idx + 3:]
            
            # Clean up any duplicate prefixes the model might have generated (e.g. AI:, 💡, or 🧠)
            full_text = re.sub(r'^(AI:\s*|💡\s*|🧠\s*|Brainstorm:\s*)*', '', full_text, flags=re.IGNORECASE).strip()
            
            lines = full_text.splitlines()
            if lines:
                # If the first line is some variation of "Follow-ups", remove it so we can print it cleanly
                if lines[0].lower().strip().startswith("follow-ups"):
                    lines = lines[1:]
                
                # Now build the clean, un-indented options block (completely flush left)
                cleaned_options = []
                for line in lines:
                    s_line = line.strip()
                    # Strip any accidental bullet characters, pointers (❯), brackets, or numbers
                    s_line = re.sub(r'^(\s*[-*❯•│├──└──\[\]\d+])*\s*', '', s_line).strip()
                    if s_line:
                        cleaned_options.append(s_line)
                
                # Print with standard green AI: prefix followed by the options (completely flush left!)
                # (Prints exactly ONE leading newline of breathing space)
                sys.stdout.write(f"\n\033[1;32mAI:\033[0m Follow-ups\n")
                for opt in cleaned_options[:option_count]:
                    sys.stdout.write(f"{opt}\n")
                sys.stdout.flush()
                
            sys.exit(0)
    except Exception:
        pass

sys.stderr.write("Error: All brainstorm service fallbacks are offline.\n")
sys.exit(1)
