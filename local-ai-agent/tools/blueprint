#!/usr/bin/env bash
# blueprint - Visualizer for ai-context.txt mappings v1.0.1

set -euo pipefail

CONTEXT_FILE="$HOME/.config/local-ai/local-ai-agent/ai-context.txt"

if [[ ! -f "$CONTEXT_FILE" ]]; then
    echo "❌ Error: Configuration file not found at $CONTEXT_FILE" >&2
    exit 1
fi

# Dynamically set ANSI colors using ANSI C-strings to render as raw escape bytes
if [[ -t 1 ]]; then
    CYAN=$'\x1b[1;36m'
    GREEN=$'\x1b[1;32m'
    YELLOW=$'\x1b[1;33m'
    GREY=$'\x1b[1;30m'
    BOLD=$'\x1b[1m'
    RESET=$'\x1b[0m'
else
    CYAN=""
    GREEN=""
    YELLOW=""
    GREY=""
    BOLD=""
    RESET=""
fi

echo -e "${CYAN}======================================================================${RESET}"
echo -e "${CYAN}                     LOCAL-AI AGENT BLUEPRINT MAP                      ${RESET}"
echo -e "${CYAN}======================================================================${RESET}"

while IFS= read -r line || [[ -n "$line" ]]; do
    # Trim leading/trailing whitespace
    line=$(echo "$line" | xargs)

    # Detect and print Section Headers
    if [[ "$line" =~ ^#\ SECTION\ ([0-9]+):\ (.*) ]]; then
        sec_num="${BASH_REMATCH[1]}"
        sec_title="${BASH_REMATCH[2]}"
        echo -e "\n${BOLD}${sec_num}. ${sec_title}${RESET}"
        echo -e "${GREY}----------------------------------------------------------------------${RESET}"
        continue
    fi

    # Skip other comments or empty lines
    if [[ "$line" =~ ^# ]] || [[ -z "$line" ]]; then
        continue
    fi

    # Parse command mappings strictly splitting on the "--->" delimiter
    if [[ "$line" == *"--->"* ]]; then
        cmd=$(echo "${line%%--->*}" | xargs)      # Strip everything from first ---> onwards [7]
        intents=$(echo "${line#*--->}" | xargs)  # Strip everything up to first ---> [7]

        # Check for tool markers
        display_cmd="$cmd"
        is_tool=false
        if [[ "$cmd" == "[TOOL]"* ]]; then
            is_tool=true
            display_cmd="${cmd#\[TOOL\]}"
            display_cmd=$(echo "$display_cmd" | xargs)
        fi

        # Shorten absolute home paths cleanly
        display_cmd="${display_cmd/#$HOME/\~}"

        # Assign contextual colors
        if [[ "$is_tool" == true ]]; then
            cmd_color="${YELLOW}"
            tool_label=" [TOOL]"
        else
            cmd_color="${GREY}"
            tool_label=""
        fi

        # Dot-leader alignment math (Expanded width to 42 to prevent truncation)
        dots="...................................................."
        pad_width=42
        pad_len=$((pad_width - ${#intents}))
        if [ $pad_len -gt 0 ]; then
            aligned_intents="${GREEN}${intents}${GREY}${dots:0:pad_len}${RESET}"
        else
            trunc_width=$((pad_width - 3))
            aligned_intents="${GREEN}${intents:0:trunc_width}...${RESET}"
        fi

        # Print beautifully aligned columns
        printf "  %s ${GREY}--->${RESET} ${cmd_color}%s${RESET}%s\n" \
            "$aligned_intents" \
            "$display_cmd" \
            "${tool_label:+${YELLOW}${tool_label}${RESET}}"
    fi
done < "$CONTEXT_FILE"

echo ""
echo -e "${CYAN}======================================================================${RESET}"
