#!/usr/bin/env python3
import os, re, subprocess, sys

p_dir = os.path.expanduser("~/.config/local-ai/local-ai-agent/tools/skills")
p_path = os.path.join(p_dir, "mysys.md")
os.makedirs(p_dir, exist_ok=True)

sys.stderr.write("Generating system profile...\n")
sys.stderr.flush()

def run(cmd):
    try: return subprocess.check_output(cmd, shell=True, text=True, stderr=subprocess.DEVNULL).strip()
    except: return "Unknown"
        
os_name, cpu = "Unknown Linux", "Unknown"
if os.path.exists("/etc/os-release"):
    with open("/etc/os-release") as f:
        m = re.search(r'^PRETTY_NAME="?([^"\n]+)"?', f.read(), re.M)
        if m: os_name = m.group(1)
    
if os.path.exists("/proc/cpuinfo"):
    with open("/proc/cpuinfo") as f:
        m = re.search(r'^model name\s*:\s*(.+)', f.read(), re.M)
        if m: cpu = m.group(1)

# 1. Detect graphics driver
driver = "Unknown"
for drv in ["xe", "i915", "nvidia", "amdgpu", "nouveau", "radeon"]:
    if os.path.exists(f"/sys/bus/pci/drivers/{drv}"):
        driver = drv
        break

# 2. Detect CachyOS/Arch x86-64 optimization level (v3/v4)
arch_v = ""
if os.path.exists("/etc/pacman.conf"):
    try:
        with open("/etc/pacman.conf") as f:
            conf = f.read()
            if "cachyos-v4" in conf: arch_v = " (v4)"
            elif "cachyos-v3" in conf: arch_v = " (v3)"
    except: pass

# 3. Detect Display / Login Manager
dm = "Unknown"
dm_symlink = "/etc/systemd/system/display-manager.service"
if os.path.islink(dm_symlink):
    try: dm = os.path.basename(os.readlink(dm_symlink)).replace(".service", "")
    except: pass

# 4. Detect Active Bootloader
bootloader = "Unknown"
if os.path.exists("/boot/loader/loader.conf") or os.path.exists("/sys/firmware/efi/efivars/LoaderEntries-4a67b082-0a4c-41cf-b647-f31302b51130"):
    bootloader = "systemd-boot"
elif os.path.exists("/boot/grub/grub.cfg"):
    bootloader = "GRUB"
elif os.path.exists("/boot/limine.cfg") or os.path.exists("/boot/limine.conf"):
    bootloader = "Limine"

gpu = run("lspci | grep -i -E 'vga|3d|display' | head -n 1 | cut -d':' -f3")
wm = os.environ.get("XDG_CURRENT_DESKTOP", "Standard Window Manager")
if "hyprland" in wm.lower() or os.environ.get("HYPRLAND_INSTANCE_SIGNATURE"): wm = "Hyprland"
elif "i3" in wm.lower(): wm = "i3"

kernel_ver = run("uname -r")
hostname_str = run("hostname")

# Dynamic rule construction based on system states
graphics_rules = ""
if wm.lower() == "hyprland" or driver in ["xe", "amdgpu"]:
    graphics_rules = f"The active graphics driver is **{driver}** running the **{wm}** Wayland compositor. Prioritize Wayland-native utilities (such as `hyprctl`, `grimblast`, `wl-copy`) and modern kernel driver configurations over deprecated X11 tools."
else:
    graphics_rules = f"The active graphics driver is **{driver}** running the **{wm}** environment. Prioritize tools and commands native to this graphics and compositor setup."

optimization_rules = ""
if "cachyos" in kernel_ver.lower() or "v4" in arch_v or "v3" in arch_v:
    optimization_rules = f"The host utilizes a performance-optimized kernel (`{kernel_ver}{arch_v}`). Always prioritize compiled-optimized packages, performance-tuned parameters, and modern scheduler suggestions (like Bore, EEVDF, or CachyOS optimizations)."
else:
    optimization_rules = "Prioritize standard package manager commands and standard execution runtimes appropriate for basic system hardware profiles."

# Structured Markdown Template for AI attention heads
profile = f"""# SYSTEM ARCHITECTURE BLUEPRINT
Host Profile context for local AI shell executions.

## Host Environment Context
* **Static Hostname**: `{hostname_str}`
* **Operating System**: `{os_name}`
* **Linux Kernel**: `{kernel_ver}{arch_v}`
* **CPU Hardware**: `{cpu}`
* **GPU Hardware**: `{gpu if gpu and gpu != "Unknown" else "Integrated Graphics"}`
* **Active Driver**: `{driver}`
* **Compositor / WM**: `{wm}`
* **Login Manager**: `{dm}`
* **Bootloader**: `{bootloader}`

---

## AI System Rules & Guidelines

### 1. OS & Windowing Alignment
All shell suggestions, scripts, and commands must strictly target **{os_name}** using the **{wm}** interface, **{dm}** display manager, and **{bootloader}** configurations. Avoid legacy alternative parameters unless explicitly requested.

### 2. Pacman & Kernel Optimization
{optimization_rules}

### 3. Wayland & Graphics Integration
{graphics_rules}

### 4. Non-Destructive Diagnostics
Suggest non-destructive terminal configurations and queries. Prioritize standard `systemd` logging and diagnosis (`journalctl`, `systemctl`) to investigate boot or active runtime issues.

### 5. Format Constraints
Keep all answers highly concise, direct, and terminal-focused.
* **CRITICAL**: Do not use markdown formatting (such as bold asterisks `**` or header hashes `#`) in your final output responses, as your output is rendered directly in a raw terminal. Use simple capitalized headers and clean vertical line spaces for visual separation.
"""

try:
    with open(p_path, "w") as f: f.write(profile)
    sys.stderr.write(f"Saved system profile successfully to {p_path}!\n")
    sys.exit(0)
except Exception as e:
    sys.stderr.write(f"Failed to save system profile: {str(e)}\n")
    sys.exit(1)
