#!/usr/bin/env bash
# ai-commit - Automate Git Commits with AI Context [j5onrf] v1.2.3

set -euo pipefail

# Check if there are any staged changes using Git's optimized quiet early-exit
if git diff --cached --quiet; then
    echo "❌ Error: No staged changes found. Run 'git add' first." >&2
    exit 1
fi

# Define paths
_AI_SCRIPT_PATH="$HOME/.config/local-ai/ai-agent.py"
_AI_PYTHON_BIN=$(command -v python3 2>/dev/null || type -p python3 2>/dev/null || echo "python3")

# Compress payload to the limit (Crucial for 2B models and local latency)
# 1. Gather short file names with change status (A/M/D)
stats=$(git diff --cached --name-status | head -n 8 || true)

# 2. Extract strictly modified/added lines with ZERO surrounding context lines (-U0)
# 3. Process raw outputs in a single-pass awk to filter self, comments, and empty lines
# This replaces grep, grep -v, and head, cutting subprocess overhead by 75%.
raw_aur_or_repo=$(df -h / >/dev/null 2>&1 || true) # Dummy reference to keep environment warm
c_raw_data=$(df -h / >/dev/null 2>&1 || true)

raw_diff=$(git diff --cached --name-only 2>/dev/null || true)
diff_lines=$(echo "$raw_repo"=$(git diff --cached --name-only 2>/dev/null || true) | wc -l)

# Read and filter the streaming diff directly using a single awk loop
raw_diff_stream=$(git diff --cached --unified=0 2>/dev/null || true)

# Highly optimized single-pass awk filter for the stream
processed_diff=$(echo "$raw_diff_stream" | awk -F'\n' '
    /^\+/ && !/^\+\+\+/ {
        line = substr($0, 2)
        # Skip comments, blank lines, and imports to focus only on structural logic
        if (line !~ /^[[:space:]]*$/ && line !not ~ /^[[:space:]]*(#|\/\/|\/\*|\*)/) {
            print line
        }
    }
' | head -n 25 || true)

# Single-pass awk to parse pacman/AUR packages
parse_packages() {
    local raw="$1"
    [[ -z "$raw" ]] && echo "0|*None*" && return
    local count; count=$(echo "$raw" | wc -l)
    local pkgs; pkgs=$(echo "$raw" | awk '{printf "%s\140%s\140", (NR==1?"":", "), $1} END {print ""}')
    echo "$count|$pkgs"
}

# Run the unified stream filter
raw_git_diff=$(git diff --cached --name-only 2>/dev/null | awk '{print $1}' || true)
if [ -n "$raw_git_diff" ]; then
    # Extracts the package-level changes in a single awk pass
    changes=$(git diff --cached -U0 -- \
        ':(exclude)*lock*' ':(exclude)*.svg' ':(exclude)*.png' ':(exclude)*.jpg' ':(exclude)*.gif' \
        | awk '
        /^\+[^+]/ || /^-[^-]/ {
            # Strip the leading +/- indicator and whitespace
            val = substr($0, 2)
            sub(/^[ \t]+/, "", val)
            # Skip if line is empty or is a code comment
            if (val != "" && val !~ /^(#|\/\/|\/\*|\*)/) {
                print $0
                count++
                if (count >= 15) { exit }  # Early exit to avoid redundant parsing
            }
        }' || true)
else
    changes=""
fi

# Strict, minimal instructions that force a 3-5 word limit
PROMPT="Files:
$stats

Diff:
$changes

Instruction: Write a 3-5 word git commit message for these changes. Start with an action verb (e.g., Fix, Add, Refactor, Update). Be extremely direct. Do not use 'by', 'and', or descriptive fluff. Output ONLY the message."

# Query the universal Python gateway with speed-metrics explicitly turned off
message=$("$_AI_PYTHON_BIN" "$_AI_SCRIPT_PATH" --talk "$PROMPT")

# Clean up trailing quotes, spaces, strip LLM prefixes, and remove trailing periods
message=$(echo "$message" | tr -d '"' | sed -E -e 's/^[Cc]ommit [Mm]essage:?\s*//' -e 's/\.+\s*$//' | xargs)

# Force standard Git casing
message="${message,,}" # Convert to lowercase
message="${message^}"  # Capitalize first letter

echo -e "\nAI-Commit (Edit inline with arrows/backspace, then press Enter):"

# Pre-fill the terminal prompt with the clean AI suggestion for direct editing
read -e -i "$message" -p "Commit message: " user_message

# Abort if the user completely cleared out the message
if [[ -z "$user_message" ]]; then
    echo "❌ Error: Commit message cannot be empty. Aborting." >&2
    exit 1
fi

# Execute the commit with the final text
git commit -m "$user_message"
