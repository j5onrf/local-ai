#!/usr/bin/env bash
# ai-commit - Automate Git Commits with AI Context

set -euo pipefail

# Gracefully handle Ctrl+C (SIGINT)
if [[ "${BASH_SOURCE[0]}" != "${0}" ]]; then
    trap 'echo -e "\n\n👋 Commit aborted."; return 130 2>/dev/null || exit 130' INT
else
    trap 'echo -e "\n\n👋 Commit aborted."; exit 130' INT
fi

# 1. Ensure we are inside a Git repository
if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
    echo "❌ Error: Not inside a git repository." >&2
    exit 1
fi

# 2. Check for staged changes; exit early if nothing is staged
stats=$(git diff --cached --name-status | head -n 8 || true)
if [[ -z "$stats" ]]; then
    echo "⚠️  No staged changes found. Run 'git add' on your files first." >&2
    exit 0
fi

# Define paths
_AI_SCRIPT_PATH="$HOME/.config/local-ai/ai-agent.py"
_AI_PYTHON_BIN=$(command -v python3 2>/dev/null || type -p python3 2>/dev/null || echo "python3")

# 3. Extract modified/added lines with ZERO surrounding context (-U0)
# Single-pass awk filters out lock/image files, comments, and blank lines
changes=$(git diff --cached -U0 -- \
    ':(exclude)*lock*' ':(exclude)*.svg' ':(exclude)*.png' ':(exclude)*.jpg' ':(exclude)*.gif' \
    | awk '
    /^\+[^+]/ || /^-[^-]/ {
        val = substr($0, 2)
        sub(/^[ \t]+/, "", val)
        if (val != "" && val !~ /^(#|\/\/|\/\*|\*)/) {
            print $0
            count++
            if (count >= 15) { exit }  # Exit early to minimize token usage
        }
    }' || true)

# 4. Strict prompt for local quantized models
PROMPT="Files:
$stats

Diff:
$changes

Instruction: Write a 3-5 word git commit message for these changes. Start with an action verb (e.g., Fix, Add, Refactor, Update). Be extremely direct. Do not use 'by', 'and', or descriptive fluff. Output ONLY the message."

# 5. Query Python AI Gateway
raw_message=$("$_AI_PYTHON_BIN" "$_AI_SCRIPT_PATH" --talk "$PROMPT" 2>/dev/null || echo "")

# 6. Safe string cleaning (Replaces xargs to handle single quotes/apostrophes cleanly)
message=$(echo "$raw_message" | sed -E \
    -e 's/^[Cc]ommit [Mm]essage:?\s*//' \
    -e 's/^[`"'\''\s]+//' \
    -e 's/[`"'\''\s\.]+$//' \
    -e 's/^[[:space:]]+//; s/[[:space:]]+$//')

# Fallback if LLM output was empty or failed
if [[ -z "$message" ]]; then
    message="Update staged files"
else
    # Capitalize the first letter
    first_char=$(echo "${message:0:1}" | tr '[:lower:]' '[:upper:]')
    message="${first_char}${message:1}"
fi

echo -e "\nAI-Commit (Edit inline with arrows/backspace, then press Enter):"

# Pre-fill the terminal prompt for direct user editing
read -e -i "$message" -p "Commit message: " user_message

# Abort if the user completely cleared out the message
if [[ -z "$user_message" ]]; then
    echo "❌ Error: Commit message cannot be empty. Aborting." >&2
    exit 1
fi

# Execute git commit
git commit -m "$user_message"
