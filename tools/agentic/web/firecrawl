#!/usr/bin/env python3
# File: ~/.config/local-ai/tools/agentic/web/firecrawl
import os
import sys
import re
import requests

ENV_PATH = os.path.expanduser("~/.config/local-ai/.env")

# 1. Safely load API credentials directly from environment or local .env
api_key = os.environ.get("FIRECRAWL_API_KEY")
if not api_key and os.path.exists(ENV_PATH):
    try:
        with open(ENV_PATH, "r", encoding="utf-8") as f:
            for line in f:
                match = re.match(r"^#?\s*FIRECRAWL_API_KEY\s*=\s*\"?([^\"]*)\"?$", line.strip())
                if match:
                    api_key = match.group(1)
                    break
    except Exception:
        pass

if not api_key:
    sys.stderr.write("❌ Error: FIRECRAWL_API_KEY not configured inside your ~/.config/local-ai/.env\n")
    sys.exit(1)

# 2. Parse command arguments or start interactive fallback wizard on-demand
target_url = ""
if len(sys.argv) >= 2:
    target_url = sys.argv[1].strip()

# If run from the selection TUI without a valid parameter, prompt the user dynamically
if not target_url or "." not in target_url or "$" in target_url:
    try:
        sys.stderr.write("\033[1;33m🌐 Enter target URL to scrape: \033[0m")
        sys.stderr.flush()
        target_url = input().strip()
    except (KeyboardInterrupt, EOFError):
        sys.stderr.write("\nCancelled.\n")
        sys.exit(130)

if not target_url:
    sys.stderr.write("❌ Error: No target URL provided.\n")
    sys.exit(1)

# Handle protocol fallbacks dynamically
if not target_url.startswith(("http://", "https://")):
    target_url = "https://" + target_url

# 3. Compile REST connection configurations
headers = {
    "Authorization": f"Bearer {api_key}",
    "Content-Type": "application/json"
}
payload = {
    "url": target_url,
    "formats": ["markdown"]
}

try:
    response = requests.post("https://api.firecrawl.dev/v1/scrape", json=payload, headers=headers, timeout=30)
    if response.status_code == 200:
        markdown_output = response.json().get("data", {}).get("markdown", "")
        if markdown_output:
            print(markdown_output)
            sys.exit(0)
        else:
            sys.stderr.write("❌ Error: Server responded successfully, but returned an empty markdown tree.\n")
            sys.exit(1)
    else:
        sys.stderr.write(f"❌ Error: {response.status_code} - {response.text}\n")
        sys.exit(1)
except Exception as e:
    sys.stderr.write(f"❌ Connection Error: {e}\n")
    sys.exit(1)
