#!/usr/bin/env python3
# web-reader [Zero-Dependency Web Scraper & YouTube Subtitle Extractor] v1.0.4
# Path: ~/.config/local-ai/tools/agentic/web/web-reader

import os
import sys
import shutil
import tempfile
import subprocess
import glob
import re
import urllib.request as urlreq

def scrape_webpage(url):
    """Uses Jina's free, cloud-native reader proxy to convert any page into clean Markdown."""
    if not url or not url.startswith(("http://", "https://")):
        sys.stderr.write("❌ Error: Please provide a valid target URL starting with http:// or https://\n")
        sys.exit(1)

    jina_url = f"https://r.jina.ai/{url}"
    try:
        req = urlreq.Request(
            jina_url,
            headers={"User-Agent": "Mozilla/5.0", "X-Return-Format": "markdown"}
        )
        with urlreq.urlopen(req, timeout=12) as res:
            content = res.read().decode("utf-8", errors="ignore")
            # Truncate to prevent overloading local-ai context limits
            print(content[:18000])
    except Exception as e:
        sys.stderr.write(f"❌ Web scrape failed: {e}\n")
        sys.exit(1)

def extract_youtube_subtitles(video_url):
    """Uses the system's native yt-dlp binary to extract video subtitles cleanly."""
    if not video_url or not video_url.startswith(("http://", "https://", "youtube.com", "youtu.be", "www.youtube.com")):
        sys.stderr.write("❌ Error: Please provide a valid YouTube URL.\n")
        sys.exit(1)

    if not shutil.which("yt-dlp"):
        sys.stderr.write("❌ Error: 'yt-dlp' is not installed. Run: sudo pacman -S yt-dlp\n")
        sys.exit(1)
        
    # Create an isolated temporary output directory
    temp_dir = tempfile.mkdtemp()
    
    # Download auto-generated English subtitles, skipping the actual video file
    cmd = [
        "yt-dlp",
        "--skip-download",
        "--write-auto-sub",
        "--sub-lang", "en",
        "-o", os.path.join(temp_dir, "%(id)s"),
        video_url
    ]
    
    try:
        subprocess.run(cmd, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, check=True)
        # Scan the temp directory for compiled .vtt subtitle files
        vtt_files = glob.glob(os.path.join(temp_dir, "*.vtt"))
        if vtt_files:
            with open(vtt_files[0], "r", encoding="utf-8") as f:
                content = f.read()
            
            # Clean VTT formatting, removing duplicates and timestamps
            clean_lines = []
            for line in content.splitlines():
                line = line.strip()
                # Skip metadata headers, blank lines, and timestamp markers
                if (not line 
                    or line.startswith(("WEBVTT", "Kind:", "Language:", "Style:"))
                    or "-->" in line 
                    or line.isdigit()):
                    continue
                
                # 1. Clean out all inline WebVTT/XML tags (e.g., <00:00:01.100> or <c>)
                line = re.sub(r'<[^>]+>', '', line).strip()
                
                # 2. Clean out any leading/trailing split tag remnants (like '00:00:01.100>' or 'c>')
                line = re.sub(r'^[^>]*>\s*', '', line).strip()
                line = re.sub(r'\s*<[^>]*$', '', line).strip()
                
                if not line:
                    continue
                
                # 3. Collapse scrolling subtitle duplications (replaces shorter lines with longer ones)
                if clean_lines:
                    prev = clean_lines[-1]
                    if line.startswith(prev) or prev in line:
                        if len(line) > len(prev):
                            clean_lines[-1] = line
                        continue
                    if prev == line:
                        continue
                        
                clean_lines.append(line)
            
            # Output first 600 lines of clean transcript
            print("\n".join(clean_lines[:600]))
        else:
            sys.stderr.write("⚠️ Warning: No auto-generated English subtitles found for this video.\n")
    except Exception as e:
        sys.stderr.write(f"❌ YouTube subtitle extraction failed: {e}\n")
    finally:
        # Securely remove temporary files
        shutil.rmtree(temp_dir)

def main():
    args = sys.argv[1:]
    
    # Scenario 1: No arguments provided (Interactive Mode Selection)
    if len(args) == 0:
        # Write prompts directly to stderr so they are visible even when stdout is piped
        sys.stderr.write("🌐 Local-AI Web Reader\n")
        sys.stderr.write("1. Scrape standard webpage\n")
        sys.stderr.write("2. Extract YouTube transcript\n")
        sys.stderr.write("❯ Select option (1/2): ")
        sys.stderr.flush()
        try:
            choice = sys.stdin.readline().strip()
            if choice == "1":
                mode = "web"
            elif choice == "2":
                mode = "youtube"
            else:
                sys.stderr.write("❌ Invalid selection.\n")
                sys.exit(1)
            
            sys.stderr.write("❯ Enter URL: ")
            sys.stderr.flush()
            url = sys.stdin.readline().strip()
        except (KeyboardInterrupt, EOFError):
            sys.stderr.write("\nCancelled.\n")
            sys.exit(130)
            
    # Scenario 2: Arguments provided (Agentic or Command Line invocation)
    else:
        mode = args[0].lower()
        
        # Combine any trailing arguments to check for parsed search queries
        raw_url = " ".join(args[1:]).strip()
        
        # Dynamically verify if the passed URL is empty, a placeholder, 
        # or just a repeat of your search terms (e.g. 'web', 'web reader')
        is_invalid_url = (
            not raw_url 
            or raw_url in ("$1", "{}") 
            or raw_url.lower() in ("web", "reader", "webr", "web reader")
            or ("." not in raw_url and not raw_url.startswith(("http://", "https://")))
        )
        
        # If the input is empty or a search artifact, prompt interactively
        if is_invalid_url:
            try:
                # Write prompt directly to stderr to prevent it from getting swallowed by the mdcat pipe
                sys.stderr.write(f"❯ Enter {mode.title()} URL to process: ")
                sys.stderr.flush()
                url = sys.stdin.readline().strip()
            except (KeyboardInterrupt, EOFError):
                sys.stderr.write("\nCancelled.\n")
                sys.exit(130)
        else:
            url = args[1].strip()
            
    # Execute the selected operation
    if mode == "web" or mode == "webr":
        scrape_webpage(url)
    elif mode == "youtube":
        extract_youtube_subtitles(url)
    else:
        print(f"Unknown mode: {mode}")
        sys.exit(1)

if __name__ == "__main__":
    main()
