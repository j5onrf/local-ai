import sys, os, json, sqlite3, time, termios, tty, select, re

CFG_DIR = os.path.expanduser("~/.config/local-ai")
SESSIONS_DIR = os.path.join(CFG_DIR, "projects", "database")
os.makedirs(SESSIONS_DIR, exist_ok=True)

TOKEN_RE = re.compile(r"[^\w\s]")
STOP_WORDS = {"is", "what", "it", "do", "any", "i", "have", "the", "a", "an", "on", "to", "for", "me", "you", "my", "your", "we", "us", "are", "about", "in", "how"}

def tokenize(t): 
    return [w for w in TOKEN_RE.sub(" ", t.lower()).split() if len(w) > 1 and w not in STOP_WORDS]

# Path Bootstrap: dynamically load local modules
SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
MODULES_DIR = os.path.join(SCRIPT_DIR, "modules")
if MODULES_DIR not in sys.path:
    sys.path.insert(0, MODULES_DIR)

try:
    import context
except ImportError:
    context = None

def get_key():
    try:
        with open("/dev/tty", "r") as tty_file:
            fd = tty_file.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                termios.tcflush(fd, termios.TCIFLUSH)
                r = os.read(fd, 1)
                if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]:
                    r += os.read(fd, 2)
                return r.decode("utf-8", errors="ignore")
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
    except:
        fd = sys.stdin.fileno()
        try: old = termios.tcgetattr(fd)
        except: return ""
        try:
            tty.setraw(fd)
            termios.tcflush(fd, termios.TCIFLUSH)
            r = os.read(fd, 1)
            if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]: r += os.read(fd, 2)
            return r.decode("utf-8", errors="ignore")
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ""

def print_session_box(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    
    turns_count = 0
    checkpoints_count = 0
    if os.path.exists(db_path):
        try:
            conn = sqlite3.connect(db_path)
            cursor = conn.cursor()
            cursor.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
            turns_count = cursor.fetchone()[0]
            cursor.execute("SELECT COUNT(*) FROM checkpoints WHERE workspace = ?", (workspace,))
            checkpoints_count = cursor.fetchone()[0]
            conn.close()
        except:
            pass

    home_dir = os.path.expanduser("~")
    workspace_path = os.environ.get("AI_WORKSPACE_PATH")
    if not workspace_path:
        rebuilt = workspace.replace("-", "/")
        if rebuilt.startswith(".config"):
            workspace_path = os.path.join(home_dir, rebuilt)
        else:
            workspace_path = rebuilt

    display_ws = workspace_path
    if display_ws.startswith(home_dir):
        display_ws = display_ws.replace(home_dir, "~", 1)

    if len(display_ws) > 28:
        display_ws = "..." + display_ws[-25:]

    # Resolve the active model dynamically using the exact same cascade as ai-agent.py
    gkey = os.environ.get("GEMINI_API_KEY")
    okey = os.environ.get("OPENROUTER_API_KEY")
    
    if gkey:
        model_name = os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite")
    elif okey:
        model_name = os.environ.get("OPENROUTER_MODEL", "openrouter/free")
    else:
        model_name = "local-model"

    # Multi-skill space extraction mapping
    active_skill = os.environ.get("AI_ACTIVE_SKILL")
    clean_name = " ".join(s.lstrip("-") for s in active_skill.split()) if active_skill else "default"

    box_width = 46
    title_line = " >_ Local-AI Session Manager"
    model_line = f" model:     {model_name}"
    dir_line   = f" directory: {display_ws}"
    skill_line = f" skill:     {clean_name}"
    db_line    = f" database:  {turns_count} turns, {checkpoints_count} saves"
    
    # Print the box strictly to stderr using standard box-drawing characters and legible 2m dim body text
    sys.stderr.write("\n\033[1;36m╭" + "─" * box_width + "╮\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m \033[1;37m{title_line:<{box_width-1}}\033[1;36m│\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m{' ':<{box_width}}\033[1;36m│\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m \033[2m{model_line:<{box_width-1}}\033[1;36m│\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m \033[2m{dir_line:<{box_width-1}}\033[1;36m│\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m \033[2m{skill_line:<{box_width-1}}\033[1;36m│\n\033[0m")
    sys.stderr.write(f"\033[1;36m│\033[0m \033[2m{db_line:<{box_width-1}}\033[1;36m│\n\033[0m")
    sys.stderr.write("\033[1;36m╰" + "─" * box_width + "╯\n\033[0m")
    sys.stderr.flush()

def init_db(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS checkpoints (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            workspace TEXT NOT NULL,
            tag TEXT NOT NULL,
            history TEXT NOT NULL,
            timestamp INTEGER NOT NULL
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS turns (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            workspace TEXT NOT NULL,
            user_msg TEXT NOT NULL,
            assistant_msg TEXT NOT NULL,
            tokens TEXT NOT NULL,
            timestamp INTEGER NOT NULL
        )
    """)
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_turns_workspace ON turns (workspace);")
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_checkpoints_workspace ON checkpoints (workspace);")
    conn.commit()
    conn.close()

def save_checkpoint(workspace, tag):
    try:
        history_data = sys.stdin.read().strip()
        json.loads(history_data) # Validate it is correct JSON
    except:
        sys.stderr.write("\033[1;31m[session-mgr] Invalid history data received via stdin.\033[0m\n")
        sys.exit(1)

    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    conn.cursor().execute("INSERT INTO checkpoints (workspace, tag, history, timestamp) VALUES (?, ?, ?, ?)", (workspace, tag, history_data, int(time.time())))
    conn.commit()
    conn.close()
    sys.stderr.write(f"\033[1;32m[session-mgr] Checkpoint '{tag}' saved to SQLite for '{workspace}'.\033[0m\n")

def rollback_checkpoint(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT tag, history, timestamp FROM checkpoints WHERE workspace = ? ORDER BY timestamp DESC", (workspace,))
    rows = cursor.fetchall()
    conn.close()
    
    # Print the session metadata box before displaying history or errors
    print_session_box(workspace)
    
    if not rows:
        sys.stderr.write(f"\033[1;31m[session-mgr] No checkpoints found for: {workspace}\033[0m\n")
        sys.exit(0)

    sys.stderr.write("\n\033[1;36m--- Active Checkpoints (SQLite) ---\033[0m\n")
    for idx, (tag, history, ts) in enumerate(rows):
        sys.stderr.write(f"[{idx}] \033[1;32m{tag}\033[0m ({len(json.loads(history))} turns) - {time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(ts))}\n")
    sys.stderr.write("\n\033[1;30mSelect index to restore, or press Esc/Ctrl+C to cancel:\033[0m\n")

    sys.stderr.write("\033[?25l"); sys.stderr.flush()
    try:
        key = ""
        while True:
            if not key:
                key = get_key()
            if not key:
                sys.stderr.write("\033[?25h")
                sys.stderr.write("\033[1;30mSelect Index: \033[0m")
                sys.stderr.flush()
                try: key = sys.stdin.readline().strip()
                except KeyboardInterrupt: key = '\x1b'
            if key in ('\x03', '\x1b', 'q', 'Q', ''):
                sys.stderr.write("\r\x1b[KCancelled.\n")
                sys.exit(0)
            if key.isdigit() and int(key) < len(rows):
                selected_tag, selected_history, _ = rows[int(key)]
                sys.stderr.write(f"\r\x1b[K\033[1;32m[session-mgr] Loading checkpoint '{selected_tag}'...\033[0m\n")
                print(selected_history)
                break
            else:
                max_idx = len(rows) - 1
                sys.stderr.write(f"\r\x1b[K\033[1;31m[session-mgr] Invalid selection. Enter 0-{max_idx} (or Esc to cancel): \033[0m")
                sys.stderr.flush()
                key = ""
    finally: sys.stderr.write("\033[?25h"); sys.stderr.flush()

def log_turn(workspace, user_msg, assistant_msg):
    if "### Real-time System Context:" in user_msg:
        user_msg = user_msg.split("User Question:", 1)[-1].strip()
    tokens_str = " ".join(tokenize(user_msg))
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    conn.cursor().execute(
        "INSERT INTO turns (workspace, user_msg, assistant_msg, tokens, timestamp) VALUES (?, ?, ?, ?, ?)",
        (workspace, user_msg, assistant_msg, tokens_str, int(time.time()))
    )
    conn.commit()
    conn.close()

def search_past_context(workspace, query):
    q_tokens = set(tokenize(query))
    if not q_tokens: return
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT user_msg, assistant_msg, tokens, timestamp FROM turns WHERE workspace = ?", (workspace,))
    rows = cursor.fetchall()
    conn.close()
    
    candidates = []
    for user_msg, assistant_msg, tokens, ts in rows:
        t_tokens = set(tokens.split())
        score = len(q_tokens & t_tokens) / len(q_tokens | t_tokens) if (q_tokens & t_tokens) else 0.0
        if score >= 0.35:
            candidates.append((score, user_msg, assistant_msg, ts))
            
    if not candidates: return
    candidates.sort(key=lambda x: -x[0])
    num_opts = len(candidates)
    
    current_idx = 0
    sys.stderr.write("\033[?25l"); sys.stderr.flush()
    try:
        while True:
            _, user_msg, assistant_msg, ts = candidates[current_idx]
            idx_str = f"[{current_idx + 1:02d}/{num_opts:02d}] ❯ " if num_opts > 1 else ""
            display_msg = user_msg.strip().replace("\n", " ")
            if len(display_msg) > 40: display_msg = display_msg[:47] + "..."
            date_str = time.strftime('%Y-%m-%d %H:%M', time.localtime(ts))
            
            # Render the active item using the highly legible dim color
            sys.stderr.write(f"\r\x1b[K\033[2m{idx_str}[memory] ({date_str})\033[0m\n")
            sys.stderr.write(f"\r\x1b[K\033[3m   \"{display_msg}\"\033[0m [↵ load  d: disable  Esc/Arrows: skip]: ")
            sys.stderr.flush()
            
            key = get_key()
            
            # Always erase the 2 printed lines immediately after key capture
            sys.stderr.write("\r\x1b[K\x1b[1A\r\x1b[K")
            sys.stderr.flush()
            
            if key == '\x03':
                sys.stderr.write("Cancelled.\n")
                sys.exit(2)
            elif key in ('\r', '\n', ''):
                sys.stderr.write(f"\033[2;32m[sys] Memory injected.\033[0m\n")
                sys.stderr.flush()
                print("\n### Relevant Past Discussion (Retrieved from Session Memory):")
                print(f"* **On {date_str} you asked**: \"{user_msg}\"\n  **Agent responded**: \"{assistant_msg.strip()}\"")
                break
            elif key in ('d', 'D'):
                sys.stderr.write("\033[2;31m[sys] Memory recall disabled. (Type /m to re-enable)\033[0m\n")
                sys.stderr.flush()
                sys.exit(3) # exit code 3 tells parent agent to turn off memory tracking
            elif key in ('\x1b[A', '\x1b[B'):
                # UP and DOWN arrows navigate (cycle carousel index)
                current_idx = (current_idx + (1 if key == '\x1b[B' else -1) + num_opts) % num_opts
            else:
                # ANY other key (including RIGHT and LEFT arrows) skips memory recall
                sys.stderr.write("\033[2;31m[sys] Memory recall skipped.\033[0m\n")
                sys.stderr.flush()
                sys.exit(0)
    finally:
        sys.stderr.write("\033[?25h"); sys.stderr.flush()

def get_turns_count(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
        print(cursor.fetchone()[0])
        conn.close()
    else:
        print(0)

if __name__ == "__main__":
    args = sys.argv[1:]
    if not args:
        sys.exit(1)
        
    cmd = args[0]
    # show-tok only relies on stdin stream JSON data; bypass workspace db initialization
    if cmd == "show-tok":
        if context:
            try:
                chat_history = json.loads(sys.stdin.read().strip())
                context.show_memory_status(chat_history, max_context=8192, server_url="http://localhost:8080")
            except Exception as e:
                sys.stderr.write(f"[session-mgr] Error rendering memory: {e}\n")
        else:
            sys.stderr.write("[session-mgr] Warning: 'context' module not found. show-tok bypassed.\n")
        sys.exit(0)
        
    if len(args) < 2:
        sys.exit(1)
        
    workspace = args[1]
    init_db(workspace)
    
    if cmd == "save":
        save_checkpoint(workspace, args[2] if len(args) > 2 else "")
    elif cmd == "load":
        rollback_checkpoint(workspace)
    elif cmd == "init":
        print_session_box(workspace)
    elif cmd == "log-turn" and len(args) >= 4:
        log_turn(workspace, args[2], args[3])
    elif cmd == "get-context" and len(args) >= 3:
        search_past_context(workspace, args[2])
    elif cmd == "get-count":
        get_turns_count(workspace)
