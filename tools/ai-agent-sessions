#!/usr/bin/env python3
# Local-Ai Session, Checkpoint, and Dynamic Memory Manager [sqlite3-backed]

import sys, os, json, sqlite3, time, termios, tty, select, re

CFG_DIR = os.path.expanduser("~/.config/local-ai")
SESSIONS_DIR = os.path.join(CFG_DIR, "projects", "database")
TOKEN_RE = re.compile(r"[^\w\s]")
STOP_WORDS = {"is", "what", "it", "do", "any", "i", "have", "the", "a", "an", "on", "to", "for", "me", "you", "my", "your", "we", "us", "are", "about", "in", "how"}

def tokenize(t): return [w for w in TOKEN_RE.sub(" ", t.lower()).split() if len(w) > 1 and w not in STOP_WORDS]

# Blocking raw-TTY keyboard grabber (With terminal input queue flushing)
def get_key():
    try:
        with open("/dev/tty", "r") as tty_file:
            fd = tty_file.fileno()
            old = termios.tcgetattr(fd)
            try:
                tty.setraw(fd)
                # Flush pending terminal buffer keys (prevents residual Enter key auto-approvals)
                termios.tcflush(fd, termios.TCIFLUSH)
                r = os.read(fd, 1) # Blocks until a fresh key is pressed
                if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]:
                    r += os.read(fd, 2)
                return r.decode("utf-8", errors="ignore")
            finally:
                termios.tcsetattr(fd, termios.TCSADRAIN, old)
    except:
        fd = sys.stdin.fileno()
        try: old = termios.tcgetattr(fd)
        except: return ""
        try:
            tty.setraw(fd)
            termios.tcflush(fd, termios.TCIFLUSH)
            r = os.read(fd, 1)
            if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]: r += os.read(fd, 2)
            return r.decode("utf-8", errors="ignore")
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return ""

# Initialize database dynamically based on active workspace name
def init_db(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS checkpoints (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            workspace TEXT NOT NULL,
            tag TEXT NOT NULL,
            history TEXT NOT NULL,
            timestamp INTEGER NOT NULL
        )
    """)
    cursor.execute("""
        CREATE TABLE IF NOT EXISTS turns (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            workspace TEXT NOT NULL,
            user_msg TEXT NOT NULL,
            assistant_msg TEXT NOT NULL,
            tokens TEXT NOT NULL,
            timestamp INTEGER NOT NULL
        )
    """)
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_turns_workspace ON turns (workspace);")
    cursor.execute("CREATE INDEX IF NOT EXISTS idx_checkpoints_workspace ON checkpoints (workspace);")
    conn.commit()
    conn.close()

# Reads the manual save history JSON directly from stdin
def save_checkpoint(workspace, tag):
    try:
        history_data = sys.stdin.read().strip()
        json.loads(history_data) # Validate it is correct JSON
    except:
        sys.stderr.write("\033[1;31m[session-mgr] Invalid history data received via stdin.\033[0m\n")
        sys.exit(1)

    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    conn.cursor().execute("INSERT INTO checkpoints (workspace, tag, history, timestamp) VALUES (?, ?, ?, ?)", (workspace, tag, history_data, int(time.time())))
    conn.commit()
    conn.close()
    sys.stderr.write(f"\033[1;32m[session-mgr] Checkpoint '{tag}' saved to SQLite for '{workspace}'.\033[0m\n")

# Writes the selected rollback history JSON directly to stdout
def rollback_checkpoint(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT tag, history, timestamp FROM checkpoints WHERE workspace = ? ORDER BY timestamp DESC", (workspace,))
    rows = cursor.fetchall()
    conn.close()
    if not rows:
        sys.stderr.write(f"\033[1;31m[session-mgr] No checkpoints found for: {workspace}\033[0m\n")
        sys.exit(0)

    sys.stderr.write("\n\033[1;36m--- Active Checkpoints (SQLite) ---\033[0m\n")
    for idx, (tag, history, ts) in enumerate(rows):
        sys.stderr.write(f"[{idx}] \033[1;32m{tag}\033[0m ({len(json.loads(history))} turns) - {time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(ts))}\n")
    sys.stderr.write("\n\033[1;30mSelect index to restore, or press Esc/Ctrl+C to cancel:\033[0m\n")

    sys.stderr.write("\033[?25l"); sys.stderr.flush()
    try:
        key = ""
        while True:
            # Only grab key if not already defined by fallback loop
            if not key:
                key = get_key()
                
            # Fallback to standard keyboard input if TTY raw-grab fails
            if not key:
                sys.stderr.write("\033[?25h") # Re-enable terminal cursor
                sys.stderr.write("\033[1;30mSelect Index: \033[0m")
                sys.stderr.flush()
                try: key = sys.stdin.readline().strip()
                except KeyboardInterrupt: key = '\x1b'
            
            # Absolute cancellations (Esc, Ctrl+C, 'q', or empty EOF)
            if key in ('\x03', '\x1b', 'q', 'Q', ''):
                sys.stderr.write("\r\x1b[KCancelled.\n")
                sys.exit(0)
            
            # Process numeric selections
            if key.isdigit() and int(key) < len(rows):
                selected_tag, selected_history, _ = rows[int(key)]
                sys.stderr.write(f"\r\x1b[K\033[1;32m[session-mgr] Loading checkpoint '{selected_tag}'...\033[0m\n")
                # Print the history string directly to stdout (captured by ai-agent.py)
                print(selected_history)
                break
            else:
                # Handle invalid selection gracefully without exiting
                max_idx = len(rows) - 1
                sys.stderr.write(f"\r\x1b[K\033[1;31m[session-mgr] Invalid selection. Enter 0-{max_idx} (or Esc to cancel): \033[0m")
                sys.stderr.flush()
                key = "" # Reset key to prompt fresh input on the next loop
    finally:
        sys.stderr.write("\033[?25h"); sys.stderr.flush()

def log_turn(workspace, user_msg, assistant_msg):
    if "### Real-time System Context:" in user_msg:
        user_msg = user_msg.split("User Question:", 1)[-1].strip()
    tokens_str = " ".join(tokenize(user_msg))
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    conn.cursor().execute(
        "INSERT INTO turns (workspace, user_msg, assistant_msg, tokens, timestamp) VALUES (?, ?, ?, ?, ?)",
        (workspace, user_msg, assistant_msg, tokens_str, int(time.time()))
    )
    conn.commit()
    conn.close()

# --- PERMISSION-GATED MEMORY RETRIEVAL (DYNAMIC SINGLE/CAROUSEL) ---
def search_past_context(workspace, query):
    q_tokens = set(tokenize(query))
    if not q_tokens: return
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("SELECT user_msg, assistant_msg, tokens, timestamp FROM turns WHERE workspace = ?", (workspace,))
    rows = cursor.fetchall()
    conn.close()
    
    candidates = []
    for user_msg, assistant_msg, tokens, ts in rows:
        t_tokens = set(tokens.split())
        score = len(q_tokens & t_tokens) / len(q_tokens | t_tokens) if (q_tokens & t_tokens) else 0.0
        if score >= 0.35:
            candidates.append((score, user_msg, assistant_msg, ts))
            
    if not candidates: return
    candidates.sort(key=lambda x: -x[0])
    num_opts = len(candidates)
    
    # CASE A: Only 1 Match -> Keep it fast, simple, and single-line
    if num_opts == 1:
        _, user_msg, assistant_msg, ts = candidates[0]
        display_msg = user_msg.strip().replace("\n", " ")
        if len(display_msg) > 50: display_msg = display_msg[:47] + "..."
            
        sys.stderr.write(f"\033[1;30m[sys] Recall past memory: \033[1;36m\"{display_msg}\"\033[1;30m? [↵ load  Esc]: \033[0m")
        sys.stderr.flush()
        
        key = get_key()
        if key in ('\r', '\n'):
            sys.stderr.write(f"\r\x1b[K\033[2;32m[sys] Memory injected.\033[0m\n")
            sys.stderr.flush()
            print("\n### Relevant Past Discussion (Retrieved from Session Memory):")
            date_str = time.strftime('%Y-%m-%d %H:%M', time.localtime(ts))
            print(f"* **On {date_str} you asked**: \"{user_msg}\"\n  **Agent responded**: \"{assistant_msg.strip()}\"")
        else:
            sys.stderr.write("\r\x1b[K\033[2;31m[sys] Memory recall skipped. Aborting.\033[0m\n")
            sys.stderr.flush()
            sys.exit(2)
            
    # CASE B: Multiple Matches -> Upgrade dynamically to an Arrow-key Selection Carousel
    else:
        current_idx = 0
        sys.stderr.write("\033[?25l"); sys.stderr.flush()
        try:
            while True:
                _, user_msg, assistant_msg, ts = candidates[current_idx]
                idx_str = f"{current_idx + 1:02d}/{num_opts:02d}"
                display_msg = user_msg.strip().replace("\n", " ")
                if len(display_msg) > 40: display_msg = display_msg[:37] + "..."
                date_str = time.strftime('%Y-%m-%d %H:%M', time.localtime(ts))
                
                # Line 1: Index and past timestamp
                sys.stderr.write(f"\r\x1b[K\033[1;30m[\033[1;32m{idx_str}\033[1;30m]\033[0m ❯ \x1b[1;36m[memory]\x1b[0m \033[90m({date_str})\033[0m\n")
                # Line 2: Query preview & key prompt
                sys.stderr.write(f"\r\x1b[K\033[3m   \"{display_msg}\"\033[0m [↵ load  Esc]: ")
                sys.stderr.flush()
                
                key = get_key()
                if key in ('\x03', '\x1b'):
                    sys.stderr.write("\r\x1b[K\x1b[1A\r\x1b[K\033[2;31m[sys] Memory recall skipped. Aborting.\033[0m\n")
                    sys.exit(2)
                if key in ('\r', ''):
                    sys.stderr.write(f"\r\x1b[K\x1b[1A\r\x1b[K\033[2;32m[sys] Memory injected.\033[0m\n")
                    sys.stderr.flush()
                    print("\n### Relevant Past Discussion (Retrieved from Session Memory):")
                    print(f"* **On {date_str} you asked**: \"{user_msg}\"\n  **Agent responded**: \"{assistant_msg.strip()}\"")
                    break
                elif key in ('\x1b[A', '\x1b[B'):
                    current_idx = (current_idx + (1 if key == '\x1b[B' else -1) + num_opts) % num_opts
                    # Clean up both lines before shifting up to draw the next slide
                    sys.stderr.write("\r\x1b[K\x1b[1A\r\x1b[K")
        finally:
            sys.stderr.write("\033[?25h"); sys.stderr.flush()

def get_turns_count(workspace):
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        conn = sqlite3.connect(db_path)
        cursor = conn.cursor()
        cursor.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
        print(cursor.fetchone()[0])
        conn.close()
    else:
        print(0)

if __name__ == "__main__":
    args = sys.argv[1:]
    if len(args) < 2: sys.exit(1)
    cmd, workspace = args[0], args[1]
    # Initialize the database with the workspace parameter parsed on command line
    init_db(workspace)
    if cmd == "save": save_checkpoint(workspace, args[2] if len(args) > 2 else "")
    elif cmd == "load": rollback_checkpoint(workspace)
    elif cmd == "log-turn" and len(args) >= 4: log_turn(workspace, args[2], args[3])
    elif cmd == "get-context" and len(args) >= 3: search_past_context(workspace, args[2])
    elif cmd == "get-count": get_turns_count(workspace)
