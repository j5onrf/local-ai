# Resolve the .email config path dynamically relative to this script's directory
SCRIPT_DIR = os.path.dirname(os.path.realpath(__file__))
EMAIL_CFG_PATH = os.path.join(SCRIPT_DIR, ".email")

def load_email_config(path: str) -> dict:
    """Loads configuration keys specifically from the dedicated .email file."""
    cfg = {}
    if os.path.exists(path):
        try:
            with open(path, "r", encoding="utf-8") as f:
                for line in f:
                    line = line.strip()
                    if line and not line.startswith("#") and "=" in line:
                        k, _, v = line.partition("=")
                        v = v.split(" #")[0].strip().strip('"').strip("'")
                        cfg[k.strip()] = v
        except Exception:
            pass
    return cfg

# Load isolated configurations
CONFIG = load_email_config(EMAIL_CFG_PATH)

IMAP_SERVER = CONFIG.get("IMAP_SERVER")
EMAIL_USER = CONFIG.get("EMAIL_USER")
APP_PASS = CONFIG.get("EMAIL_APP_PASSWORD")

def clean_header(header_val) -> str:
    """Safely decodes raw mime headers into standard UTF-8 strings."""
    if not header_val:
        return "(No Subject)"
    decoded = decode_header(header_val)
    parts = []
    for text, charset in decoded:
        if isinstance(text, bytes):
            try:
                parts.append(text.decode(charset or "utf-8", errors="ignore"))
            except Exception:
                parts.append(text.decode("utf-8", errors="ignore"))
        else:
            parts.append(text)
    return "".join(parts).strip()

def highlight_tags(text: str, tags: list, color_code: str = "\033[1;33m", reset_code: str = "\033[0m") -> str:
    """Highlights configured keywords in bold/color while preserving case and surrounding styles."""
    if not tags:
        return text
    # Sort tags by length descending to prevent partial-word replacement collisions
    sorted_tags = sorted(tags, key=len, reverse=True)
    highlighted = text
    for tag in sorted_tags:
        pattern = re.compile(re.escape(tag), re.IGNORECASE)
        # Wrap matched keyword, then apply the surrounding reset_code to restore text style
        highlighted = pattern.sub(lambda m: f"{color_code}{m.group(0)}{reset_code}", highlighted)
    return highlighted

def fetch_single_account(acc: dict, limit: int) -> list:
    """Connects to a single mailbox and lazily fetches unread matching emails."""
    emails_list = []
    try:
        mail = imaplib.IMAP4_SSL(acc["server"], timeout=10)
        mail.login(acc["user"], acc["pass"])
        mail.select("inbox")
        
        status, data = mail.search(None, "UNSEEN")
        if status != "OK" or not data[0]:
            mail.logout()
            return []
            
        mail_ids = data[0].split()
        fetch_limit = 50 if acc["tags"] else limit
        target_ids = mail_ids[-fetch_limit:]
        
        matched_count = 0
        for mid in reversed(target_ids):
            if matched_count >= limit:
                break
                
            # 1. Fetch ONLY the lightweight headers (Saves 99% of bandwidth)
            status, hdata = mail.fetch(mid, "(RFC822.HEADER)")
            if status != "OK" or not hdata or not hdata[0]:
                continue
            raw_headers = hdata[0][1]
            msg = email.message_from_bytes(raw_headers)
            
            subject = clean_header(msg["Subject"])
            sender = clean_header(msg["From"])
            
            # 2. Apply fast tag filtering strictly on the Subject line
            if acc["tags"]:
                subject_lower = subject.lower()
                if not any(tag in subject_lower for tag in acc["tags"]):
                    continue
            
            # 3. Only if it matches do we fetch a tiny 500-char plain-text snippet (non-marking)
            snippet = "(No preview available)"
            try:
                status, sdata = mail.fetch(mid, "(BODY.PEEK[1]<0.500>)")
                if status == "OK" and sdata and sdata[0]:
                    raw_snippet = sdata[0][1]
                    if raw_snippet:
                        snippet = raw_snippet.decode("utf-8", errors="ignore").strip()
                        # Clean up formatting, replacing double-spacing/newlines with space
                        snippet = re.sub(r'\s+', ' ', snippet)
                        snippet = snippet[:150] + "..." if len(snippet) > 150 else snippet
            except Exception:
                pass
            
            emails_list.append({
                "id": mid.decode("utf-8"),
                "account": acc["user"],
                "sender": sender,
                "subject": subject,
                "snippet": snippet,
                "tags": acc["tags"]
            })
            matched_count += 1
            
        mail.logout()
    except Exception as e:
        sys.stderr.write(f"❌ Connection failure for {acc['user']}: {e}\n")
    return emails_list

def fetch_emails(limit: int = 10) -> list:
    """Queries all configured mailboxes in parallel threads and aggregates the results."""
    discovered_accounts = {}
    
    # 1. Fallback: Parse legacy flat account if configured
    legacy_user = CONFIG.get("EMAIL_USER")
    legacy_pass = CONFIG.get("EMAIL_APP_PASSWORD")
    if legacy_user and legacy_pass:
        tags_str = CONFIG.get("ALLOWED_TAGS", "") or CONFIG.get("ALLOWED_TAGS_1", "")
        discovered_accounts[1] = {
            "user": legacy_user,
            "pass": legacy_pass,
            "server": CONFIG.get("IMAP_SERVER", "imap.gmail.com"),
            "tags_str": tags_str
        }
        
    # 2. Dynamic Scan: Find any numbered keys like EMAIL_USER_1, EMAIL_USER_2, etc.
    for k, v in CONFIG.items():
        match = re.match(r"^EMAIL_USER_(\d+)$", k)
        if match:
            idx = int(match.group(1))
            password = CONFIG.get(f"EMAIL_APP_PASSWORD_{idx}")
            if password:
                server = CONFIG.get(f"IMAP_SERVER_{idx}") or CONFIG.get("IMAP_SERVER", "imap.gmail.com")
                tags_str = CONFIG.get(f"ALLOWED_TAGS_{idx}", "")
                discovered_accounts[idx] = {
                    "user": v,
                    "pass": password,
                    "server": server,
                    "tags_str": tags_str
                }

    # Convert discovered map into a clean, index-sorted list
    resolved_accounts = []
    for idx in sorted(discovered_accounts.keys()):
        acc = discovered_accounts[idx]
        tag_list = [t.strip().lower() for t in acc["tags_str"].split(",") if t.strip()]
        resolved_accounts.append({
            "user": acc["user"],
            "pass": acc["pass"],
            "server": acc["server"],
            "tags": tag_list
        })

    if not resolved_accounts:
        sys.stderr.write("❌ Configuration error. Check your .email file.\n")
        return []
    
    aggregated_emails = []
    
    # 3. Query all mailboxes concurrently in parallel threads
    with concurrent.futures.ThreadPoolExecutor(max_workers=len(resolved_accounts)) as executor:
        futures = {executor.submit(fetch_single_account, acc, limit): acc for acc in resolved_accounts}
        for future in concurrent.futures.as_completed(futures):
            res = future.result()
            if res:
                aggregated_emails.extend(res)
            
    return aggregated_emails

def run_interactive_tui():
    """Runs a fast, responsive ANSI-escaped terminal selection menu for your mail."""
    # 1. Hide the terminal cursor immediately so it does not obscure your text
    sys.stderr.write("\033[?25l")
    
    # 2. Print the descriptive loading label with 2 leading spaces for alignment
    sys.stderr.write("  \033[2mConnecting to mailboxes... \033[0m")
    sys.stderr.flush()

    # 3. Start the rotating spinner if TTY is active (with no positional arguments)
    spinner = None
    if HAS_UI and sys.stderr.isatty():
        try:
            spinner = ui.InlineSpinner()
            spinner.start()
        except Exception:
            pass
        
    try:
        # Secure the mail list (Catching interrupts during connection/fetching)
        emails = fetch_emails(10)
    except KeyboardInterrupt:
        if spinner:
            try: spinner.stop()
            except: pass
        sys.stderr.write("\r\x1b[KCancelled.\n")
        sys.stderr.write("\033[?25h")  # Ensure cursor is restored
        sys.stderr.flush()
        sys.exit(130)
    
    # Teardown spinner
    if spinner:
        spinner.stop()
    sys.stderr.write("\r\x1b[K")
    sys.stderr.flush()
    
    if not emails:
        print("📭 Your inboxes are clean! No unread filtered messages found.")
        sys.stderr.write("\033[?25h")  # Restore cursor if no mail found
        sys.stderr.flush()
        return

    current_idx = 0
    num_opts = len(emails)
    
    # Cursor is already hidden, so we enter the selection loop directly
    try:
        while True:
            selected = emails[current_idx]
            idx_str = f"{current_idx + 1:02d}/{num_opts:02d}"
            
            # Highlight matched tags in Subject, restoring italics (\033[3m) on reset
            subject_highlighted = highlight_tags(
                selected['subject'][:60], 
                selected['tags'], 
                color_code="\033[1;33m", # Bold Yellow
                reset_code="\033[0m\033[3m" # Reset and restore italics
            )
            
            # Highlight matched tags in Preview snippet
            preview_highlighted = highlight_tags(
                selected['snippet'][:75], 
                selected['tags'], 
                color_code="\033[1;33m", # Bold Yellow
                reset_code="\033[0m"
            )
            
            # Print TUI selection layout (4 lines)
            sys.stderr.write(f"\r\x1b[K\033[1;30m[\033[1;32m{idx_str}\033[1;30m]\033[0m ❯ \033[1;35m[{selected['account']}]\033[0m ❯ \033[1;36m[From]\033[0m \033[1;32m{selected['sender'][:35]}\033[0m\n")
            sys.stderr.write(f"\r\x1b[K\033[3m   Subject: \"{subject_highlighted}\"\033[0m\n")
            sys.stderr.write(f"\r\x1b[K   Preview: {preview_highlighted}\n")
            sys.stderr.write(f"\r\x1b[K   [Arrows to navigate  Esc to exit]: ")
            sys.stderr.flush()
            
            key = ui.get_key()
            if key in ('\x03', '\x1b', 'q', 'Q', '\r', ''):
                sys.stderr.write("\r\x1b[K\x1b[3A\r\x1b[KExited.\n")
                break
            elif key in ('\x1b[A', '\x1b[B'):
                current_idx = (current_idx + (1 if key == '\x1b[B' else -1) + num_opts) % num_opts
                sys.stderr.write("\r\x1b[K\x1b[3A\r\x1b[K")
            else:
                sys.stderr.write("\r\x1b[K\x1b[3A\r\x1b[K")
    except KeyboardInterrupt:
        sys.stderr.write("\r\x1b[K\x1b[3A\r\x1b[KCancelled.\n")
        sys.stderr.flush()
        sys.exit(130)
    finally:
        sys.stderr.write("\033[?25h")  # Safely restore terminal cursor on exit
        sys.stderr.flush()

def main():
    run_interactive_tui()

if __name__ == "__main__":
    try:
