# --- SYSTEM UTILS ---
def safe_exit(code=0):
    try: sys.stdout.flush(); sys.stderr.flush()
    except: pass
    try: sys.stdout, sys.stderr = open(os.devnull, 'w'), open(os.devnull, 'w')
    except: pass
    sys.exit(code)

def get_key():
    try:
        import tty, termios, select
    except ImportError:
        try: return sys.stdin.read(1)
        except: return ""
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except termios.error:
        try: return os.read(fd, 1).decode("utf-8", errors="ignore")
        except: return ""
    try:
        tty.setraw(fd); r = os.read(fd, 1)
        if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]: r += os.read(fd, 2)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return r.decode("utf-8", errors="ignore")

def load_gitignore_patterns(target_dir):
    path = os.path.join(target_dir, ".gitignore")
    if os.path.isfile(path):
        try:
            with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                return [line.strip() for line in f if line.strip() and not line.strip().startswith(('#', '!'))]
        except Exception: pass
    return []

def should_ignore(rel_path, is_dir, gitignore_patterns, default_ignored_dirs):
    norm_path = rel_path.replace(os.sep, '/')
    parts = norm_path.split('/')
    if any(p in default_ignored_dirs for p in parts): return True
    
    for pattern in gitignore_patterns:
        pat, dir_only = pattern.rstrip('/'), pattern.endswith('/')
        if dir_only and not is_dir: continue
        
        anchored = False
        if pat.startswith('/'): pat, anchored = pat[1:], True
        
        if anchored:
            target = norm_path if not dir_only else norm_path.rstrip('/')
            if fnmatch.fnmatchcase(target, pat): return True
            pat_parts = pat.split('/')
            if len(parts) >= len(pat_parts) and fnmatch.fnmatchcase('/'.join(parts[:len(pat_parts)]), pat):
                return True
        else:
            for i, part in enumerate(parts):
                if dir_only and i == len(parts) - 1 and not is_dir: continue
                if fnmatch.fnmatchcase(part, pat): return True
                if '/' in pat:
                    p_len = len(pat.split('/'))
                    for j in range(len(parts) - p_len + 1):
                        if fnmatch.fnmatchcase('/'.join(parts[j:j+p_len]), pat): return True
    return False

def is_binary(filepath):
    try:
        with open(filepath, 'rb') as f: return b'\x00' in f.read(1024)
    except Exception: return True

def get_file_summary(filepath, limit=15, is_shell=False):
    """Consolidated, high-speed single-pass text summary and description extractor."""
    if not os.path.isfile(filepath) or is_binary(filepath):
        return ""
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            for _ in range(limit):
                line = f.readline()
                if not line: break
                s = line.strip()
                if not s or s.startswith('#!'):
                    continue
                # Clean up common commenting prefixes natively in a fast slice check
                s = s.lstrip('#/ \t')
                if s.lower().startswith(("file:", "path:")):
                    continue
                return s[:100].strip()
    except Exception:
        pass
    return ""

# --- AST VISITOR FOR PYTHON SYMBOLS & INTERNAL CALLS ---
class PythonGraphVisitor(ast.NodeVisitor):
    def __init__(self, filepath):
        self.filepath = filepath
        self.classes = []  # (name, start_line, end_line)
        self.functions = []  # (name, parent_class, start_line, end_line, args)
        self.calls = []  # (caller_func, caller_class, callee, line)
        self.imports = []  # (module_full_name, imported_as_name)
        self.current_class = None
        self.current_function = None

    def visit_Import(self, node):
        for alias in node.names:
            self.imports.append((alias.name, alias.asname or alias.name))
        self.generic_visit(node)

    def visit_ImportFrom(self, node):
        if node.module:
            for alias in node.names:
                self.imports.append((f"{node.module}.{alias.name}", alias.asname or alias.name))
        self.generic_visit(node)

    def visit_ClassDef(self, node):
        prev_class = self.current_class
        self.current_class = node.name
        end_line = getattr(node, 'end_lineno', node.lineno)
        self.classes.append((node.name, node.lineno, end_line))
        self.generic_visit(node)
        self.current_class = prev_class

    def visit_FunctionDef(self, node): self.visit_any_func(node)
    def visit_AsyncFunctionDef(self, node): self.visit_any_func(node)

    def visit_any_func(self, node):
        prev_func = self.current_function
        self.current_function = node.name
        end_line = getattr(node, 'end_lineno', node.lineno)
        args_list = [arg.arg for arg in node.args.args]
        self.functions.append((node.name, self.current_class, node.lineno, end_line, args_list))
        self.generic_visit(node)
        self.current_function = prev_func

    def visit_Call(self, node):
        if self.current_function:
            callee = None
            if isinstance(node.func, ast.Name):
                callee = node.func.id
            elif isinstance(node.func, ast.Attribute):
                callee = node.func.attr
            if callee:
                self.calls.append((self.current_function, self.current_class, callee, node.lineno))
        self.generic_visit(node)

# --- HYBRID REGEX-BASED MULTI-LANGUAGE PARSER ---
def parse_non_python_file(filepath, ext):
    lang = {
        '.rs': 'rust', '.go': 'go', '.lua': 'lua',
        '.js': 'javascript', '.ts': 'typescript',
        '.cpp': 'cpp', '.hpp': 'cpp', '.c': 'c', '.h': 'c'
    }.get(ext)
    
    empty_result = {'classes': [], 'functions': [], 'calls': [], 'imports': []}
    if not lang or lang not in LANG_RULES:
        return empty_result
        
    rules = LANG_RULES[lang]
    classes, functions, calls = [], [], []
    
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            lines = f.readlines()
    except Exception:
        return empty_result
        
    current_class, current_func = None, None
    for idx, line in enumerate(lines, 1):
        clean_line = line.strip()
        # High-speed sub-slice index lookup bypasses slow multi-startswith evaluations
        if not clean_line or clean_line[:2] in ('//', '/*', '--') or clean_line[0] == '#':
            continue
            
        class_match = re.search(rules['class_pattern'], clean_line)
        if class_match:
            current_class = class_match.group(1)
            classes.append((current_class, idx, idx))
            
        func_match = re.search(rules['func_pattern'], clean_line)
        if func_match:
            if current_func and functions:
                functions[-1] = (functions[-1][0], functions[-1][1], functions[-1][2], idx - 1, [])
            func_name = next((g for g in func_match.groups() if g), None)
            if func_name:
                current_func = func_name
                functions.append((func_name, current_class, idx, idx, []))
                
        if current_func:
            call_matches = re.findall(rules['call_pattern'], clean_line)
            for callee in call_matches:
                if callee not in ('if', 'for', 'while', 'switch', 'return', 'fn', 'func', 'function', 'struct', 'class', 'let', 'const', 'var', 'import', 'require'):
                    if callee != current_func:
                        calls.append((current_func, current_class, callee, idx))
                        
    if current_func and functions:
        functions[-1] = (functions[-1][0], functions[-1][1], functions[-1][2], len(lines), [])
        
    return {'classes': classes, 'functions': functions, 'calls': calls, 'imports': []}

def analyze_markdown_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        title = ""
        tm = re.search(r'^#\s+(.*)', content, re.M)
        if tm: title = tm.group(1).strip()
        tags = set()
        fm_match = re.search(r'^---\s*\n(.*?)\n---\s*\n', content, re.DOTALL)
        if fm_match:
            fm_text = fm_match.group(1)
            tags_match = re.search(r'tags\s*:\s*[\[\']?([^\]\']+)\]?', fm_text, re.I)
            if tags_match:
                tags.update(t.strip().lower() for t in tags_match.group(1).split(',') if t.strip())
        links = set()
        for w in re.findall(r'\[\[([^#\]|]+)(?:#[^\]|]+)?(?:\|[^\]]+)?\]\]', content):
            links.add(w.strip())
        for ml in re.findall(r'\[[^\]]+\]\(([^)]+\.(?:md|txt|py|sh|rs|go|lua))\)', content):
            if not ml.startswith(("http", "https")):
                links.add(os.path.basename(ml))
        return {"type": "markdown", "title": title or os.path.splitext(os.path.basename(filepath))[0], "tags": sorted(list(tags)) if tags else [], "links": sorted(list(links)) if links else []}
    except Exception:
        return {"type": "markdown", "title": os.path.splitext(os.path.basename(filepath))[0]}

def analyze_image_file(filepath):
    ext = os.path.splitext(filepath)[1].lstrip('.').lower()
    size_bytes = os.path.getsize(filepath)
    size_str = f"{size_bytes / 1024:.1f}KB" if size_bytes < 1024*1024 else f"{size_bytes / (1024*1024):.1f}MB"
    try:
        with open(filepath, 'rb') as f: head = f.read(512)
        w, h = 0, 0
        if ext == "png" and head.startswith(b'\x89PNG\r\n\x1a\n'):
            import struct
            w, h = struct.unpack('>II', head[16:24])
        elif ext == "gif" and (head.startswith(b'GIF87a') or head.startswith(b'GIF89a')):
            import struct
            w, h = struct.unpack('<HH', head[6:10])
        elif ext in ("jpg", "jpeg") and head.startswith(b'\xff\xd8'):
            import struct
            f_idx = 2
            while f_idx < len(head):
                marker, length = struct.unpack('>HH', head[f_idx:f_idx+4])
                if 0xffc0 <= marker <= 0xffc3:
                    h, w = struct.unpack('>HH', head[f_idx+5:f_idx+9])
                    break
                f_idx += length + 2
        elif ext == "svg":
            text = head.decode("utf-8", errors="ignore")
            wm = re.search(r'width\s*=\s*["\']([^"\']+)["\']', text)
            hm = re.search(r'height\s*=\s*["\']([^"\']+)["\']', text)
            return {"type": "image/svg", "dim": f"{wm.group(1) if wm else ''}x{hm.group(1) if hm else ''}", "size": size_str}
        if w and h: return {"type": f"image/{ext}", "dim": f"{w}x{h}", "size": size_str}
        return {"type": f"image/{ext}", "size": size_str}
    except Exception:
        return {"type": f"image/{ext}", "size": size_str}

def analyze_json_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: data = json.load(f)
        return {"type": "json", "keys": list(data.keys()) if isinstance(data, dict) else []}
    except: return {"type": "json", "error": "Malformed JSON"}

def analyze_qml_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        content = re.sub(r'//.*|/\*.*?\*/', '', content, flags=re.DOTALL)
        return {"type": "qml", "properties": re.findall(r'\bproperty\s+\w+\s+(\w+)', content), "functions": re.findall(r'\bfunction\s+(\w+)', content)}
    except: return {"type": "qml", "error": "Unparseable"}

def analyze_shell_file(filepath):
