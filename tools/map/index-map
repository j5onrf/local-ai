def safe_exit(code=0):
    try: sys.stdout.flush(); sys.stderr.flush()
    except: pass
    try: sys.stdout, sys.stderr = open(os.devnull, 'w'), open(os.devnull, 'w')
    except: pass
    sys.exit(code)

def get_key():
    try:
        import tty, termios, select
    except ImportError:
        try: return sys.stdin.read(1)
        except: return ""
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except termios.error:
        try: return os.read(fd, 1).decode("utf-8", errors="ignore")
        except: return ""
    try:
        tty.setraw(fd); r = os.read(fd, 1)
        if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]: r += os.read(fd, 2)
    finally: termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return r.decode("utf-8", errors="ignore")

def load_gitignore_patterns(target_dir):
    path = os.path.join(target_dir, ".gitignore")
    if os.path.isfile(path):
        try:
            with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                return [line.strip() for line in f if line.strip() and not line.strip().startswith(('#', '!'))]
        except Exception: pass
    return []

def should_ignore(rel_path, is_dir, gitignore_patterns, default_ignored_dirs):
    norm_path = rel_path.replace(os.sep, '/')
    parts = norm_path.split('/')
    if any(p in default_ignored_dirs for p in parts): return True
    
    for pattern in gitignore_patterns:
        pat, dir_only = pattern.rstrip('/'), pattern.endswith('/')
        if dir_only and not is_dir: continue
        
        anchored = False
        if pat.startswith('/'): pat, anchored = pat[1:], True
        
        if anchored:
            target = norm_path if not dir_only else norm_path.rstrip('/')
            if fnmatch.fnmatchcase(target, pat): return True
            pat_parts = pat.split('/')
            if len(parts) >= len(pat_parts) and fnmatch.fnmatchcase('/'.join(parts[:len(pat_parts)]), pat):
                return True
        else:
            for i, part in enumerate(parts):
                if dir_only and i == len(parts) - 1 and not is_dir: continue
                if fnmatch.fnmatchcase(part, pat): return True
                if '/' in pat:
                    p_len = len(pat.split('/'))
                    for j in range(len(parts) - p_len + 1):
                        if fnmatch.fnmatchcase('/'.join(parts[j:j+p_len]), pat): return True
    return False

def is_binary(filepath):
    try:
        with open(filepath, 'rb') as f: return b'\x00' in f.read(1024)
    except Exception: return True

def get_text_summary(filepath, limit=15, is_shell=False, strip_hash=True):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            for _ in range(limit):
                line = f.readline()
                if not line: break
                stripped = line.strip()
                if not stripped or (is_shell and stripped.startswith('#!')): continue
                if not strip_hash: return stripped[:120]
                if stripped.startswith('#'): return stripped.lstrip('# ').strip()[:120]
                if not is_shell: return stripped[:120]
        return ""
    except: return ""

def analyze_python_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='replace') as f: content = f.read()
        with warnings.catch_warnings():
            warnings.simplefilter("ignore", SyntaxWarning)
            tree = ast.parse(content, filename=filepath)
        funcs, classes, imports = [], [], set()
        for node in ast.walk(tree):
            if isinstance(node, (ast.FunctionDef, ast.AsyncFunctionDef)):
                args_list = [a.arg for a in node.args.args]
                funcs.append(f"{node.name}({','.join(args_list)})")
            elif isinstance(node, ast.ClassDef): classes.append(node.name)
            elif isinstance(node, ast.Import): imports.update(n.name.split('.')[0] for n in node.names)
            elif isinstance(node, ast.ImportFrom):
                if node.module: imports.add(node.module.split('.')[0])
        return {"type": "python", "imports": sorted(list(imports)), "classes": classes, "functions": funcs}
    except SyntaxError: return {"type": "python", "error": "Syntax Error"}
    except Exception as e: return {"type": "python", "error": str(e)}

def analyze_rust_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        content = re.sub(r'//.*|/\*.*?\*/', '', content, flags=re.DOTALL)
        return {"type": "rust", "classes": re.findall(r'\bstruct\s+(\w+)', content), "functions": re.findall(r'\bfn\s+(\w+)', content)}
    except: return {"type": "rust", "error": "Unparseable"}

def analyze_go_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        content = re.sub(r'//.*|/\*.*?\*/', '', content, flags=re.DOTALL)
        return {"type": "go", "classes": re.findall(r'\btype\s+(\w+)\s+struct\b', content), "functions": re.findall(r'\bfunc\s+(?:\([^)]+\)\s+)?(\w+)', content)}
    except: return {"type": "go", "error": "Unparseable"}

def analyze_lua_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        return {"type": "lua", "classes": [], "functions": re.findall(r'\bfunction\s+([\w.:]+)', re.sub(r'--.*', '', content))}
    except: return {"type": "lua", "error": "Unparseable"}

def analyze_json_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: data = json.load(f)
        return {"type": "json", "keys": list(data.keys()) if isinstance(data, dict) else []}
    except: return {"type": "json", "error": "Malformed JSON"}

def analyze_qml_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        content = re.sub(r'//.*|/\*.*?\*/', '', content, flags=re.DOTALL)
        return {"type": "qml", "properties": re.findall(r'\bproperty\s+\w+\s+(\w+)', content), "functions": re.findall(r'\bfunction\s+(\w+)', content)}
    except: return {"type": "qml", "error": "Unparseable"}

def analyze_shell_file(filepath):
    return {"type": "shell", "summary": get_text_summary(filepath, 10, True, True) or "Shell Module"}

def analyze_generic_file(filepath):
    ext = os.path.splitext(filepath)[1].lstrip('.').lower() or "file"
    if is_binary(filepath): return {"type": f"binary/{ext}"}
    return {"type": ext, "summary": get_text_summary(filepath, 15, False, False) or "Empty file"}

def compile_flat_shorthand(skeleton):
    lines = []
    for rel_path, data in sorted(skeleton.items()):
        t = data.get("type", "file")
        if t == "python":
            imp = f"imp:{','.join(data.get('imports', []))}" if data.get('imports') else ""
            cls = f"cls:{','.join(data.get('classes', []))}" if data.get('classes') else ""
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            meta = " | ".join(filter(None, [imp, cls, fn]))
            lines.append(f"[py:{rel_path}] {meta}")
        elif t in ("rust", "go", "qml"):
            cls = f"cls:{','.join(data.get('classes', []))}" if data.get('classes') else ""
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            meta = " | ".join(filter(None, [cls, fn]))
            lines.append(f"[{t}:{rel_path}] {meta}")
        elif t == "lua":
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            lines.append(f"[{t}:{rel_path}] {fn}")
        elif t == "json":
            keys = f"keys:{','.join(data.get('keys', []))}" if data.get('keys') else ""
            lines.append(f"[{t}:{rel_path}] {keys}")
        else:
            summary = data.get("summary", "").replace("\n", " ").strip()
            lines.append(f"[{t}:{rel_path}] sum:{summary}")
    return "\n".join(lines)

def generate_skeleton(target_dir):
    skeleton = {}
    default_ignored = {
        '.git', '__pycache__', 'logs', '.auto-f', 'node_modules', 
        'venv', '.venv', 'SSD_BACKUPS', '.cargo', '.rustup', 
        '.cache', '.npm', '.local', '.mozilla', 'target'
    }
    patterns = load_gitignore_patterns(target_dir)
    dispatch = {
        '.py': analyze_python_file, '.md': None, 
        '.sh': analyze_shell_file, '.bash': analyze_shell_file,
        '.rs': analyze_rust_file, '.go': analyze_go_file,
        '.lua': analyze_lua_file, '.json': analyze_json_file, '.qml': analyze_qml_file
    }
    file_count = 0
    
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not should_ignore(os.path.relpath(os.path.join(root, d), target_dir), True, patterns, default_ignored)]
        for file in files:
            filepath = os.path.join(root, file)
            rel_path = os.path.relpath(filepath, target_dir)
            if should_ignore(rel_path, False, patterns, default_ignored): continue
            
            file_count += 1
            if file_count == 1000:
                sys.stderr.write(f"\n\033[1;33m[sys] Warning: Scanned 1,000 files. Proceed? (y/N): \033[0m"); sys.stderr.flush()
                try:
                    if sys.stdin.readline().strip().lower() not in ['y', 'yes']: safe_exit(0)
                except: safe_exit(0)
            
            ext = os.path.splitext(file)[1].lower()
            if ext == '.md':
                # Local line-based parsing: extracts the top title line from the markdown file
                summary = get_text_summary(filepath, limit=15, is_shell=False, strip_hash=True) or "Documentation Module"
                skeleton[rel_path] = {"type": "markdown", "summary": summary}
            else:
                skeleton[rel_path] = dispatch.get(ext, analyze_generic_file)(filepath)
    return skeleton

def main():
    default_dir = os.getcwd()
    args = sys.argv[1:]
    
    # Check for --force flag to bypass prompt in automated/scripted loops
    force = "--force" in args
    if force:
        args = [a for a in args if a != "--force"]
        
    # Check if a directory path argument was passed via command line
    if args:
        target_dir = os.path.abspath(os.path.expanduser(os.path.expandvars(args[0])))
    else:
        # Fallback to interactive terminal prompt if executed manually
        try:
            sys.stderr.write(f"\033[1;32mScan target [Default: {default_dir}]: \033[0m"); sys.stderr.flush()
            user_input = sys.stdin.readline().strip()
            target_dir = os.path.abspath(os.path.expanduser(os.path.expandvars(user_input))) if user_input else default_dir
        except (KeyboardInterrupt, EOFError):
            sys.stderr.write("\n✕ Operation cancelled.\n"); sys.stderr.flush(); return

    if not os.path.isdir(target_dir):
        sys.stderr.write(f"❌ Error: '{target_dir}' is not a valid directory.\n"); sys.stderr.flush(); safe_exit(1)

    # Interactive Confirmation Check with Esc Bypass (Using the highly legible 2m dim colors)
    is_interactive = sys.stdin.isatty() and sys.stderr.isatty()
    if is_interactive and not force:
        try:
            sys.stderr.write(f"\033[2m[sys] Compile index map for \033[1;36m{os.path.basename(target_dir)}\033[0;2m? [↵ run  Esc]: \033[0m")
            sys.stderr.flush()
            key = get_key()
            if key in ('\x03', '\x1b', 'n', 'N'):
                sys.stderr.write("\r\x1b[K\033[2;31m[sys] Bypassed mapping execution.\033[0m\n")
                sys.stderr.flush()
                safe_exit(0)
            sys.stderr.write("\r\x1b[K")
            sys.stderr.flush()
        except Exception:
            pass

    if target_dir == os.path.expanduser("~"):
        try:
            sys.stderr.write("\n\033[1;33m[sys] Warning: Scanning entire Home Directory. Proceed? (y/N): \033[0m"); sys.stderr.flush()
            if sys.stdin.readline().strip().lower() not in ['y', 'yes']: safe_exit(0)
        except: safe_exit(0)

    sys.stderr.write("ℹ Compiling index map...\n"); sys.stderr.flush()
    skeleton = generate_skeleton(target_dir)
    
    flat_map = compile_flat_shorthand(skeleton)
    
    # Determine unique, workspace-specific file path inside target_dir
    proj_name = os.path.basename(target_dir)
    output_file = os.path.join(target_dir, f"index-map-{proj_name}.txt")
    
    home_dir = os.path.expanduser("~")

    try:
        with open(output_file, 'w', encoding='utf-8') as f: f.write(flat_map)
        
        # Format the main success path
        display_map = output_file
        if display_map.startswith(home_dir):
            display_map = display_map.replace(home_dir, "~", 1)
        if "/.config/local-ai/projects/" in display_map:
            display_map = display_map.replace("/.config/local-ai/projects/", "/")
            
        print(f"✔ Compressed index-map: {display_map}")
    except (IOError, OSError):
        fallback_file = os.path.join(os.getcwd(), f"index-map-{proj_name}.txt")
        try:
            with open(fallback_file, 'w', encoding='utf-8') as f: f.write(flat_map)
            
            # Format the fallback success path
            display_fallback = fallback_file
            if display_fallback.startswith(home_dir):
                display_fallback = display_fallback.replace(home_dir, "~", 1)
            if "/.config/local-ai/projects/" in display_fallback:
                display_fallback = display_fallback.replace("/.config/local-ai/projects/", "/")
                
            print(f"⚠ SCRIPT_DIR is read-only. Saved to fallback: {display_fallback}")
        except Exception as e: print(f"❌ Error: Failed to write map. {e}")

if __name__ == "__main__":
    main()
