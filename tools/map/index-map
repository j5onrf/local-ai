LANG_RULES = {
    'rust': {
        'class_pattern': r'\b(?:struct|enum|trait|union)\s+(\w+)',
        'func_pattern': r'\bfn\s+(\w+)',
        'call_pattern': r'\b(\w+)\s*\('
    },
    'go': {
        'class_pattern': r'\btype\s+(\w+)\s+struct\b',
        'func_pattern': r'\bfunc\s+(?:\([^)]+\)\s+)?(\w+)',
        'call_pattern': r'\b(\w+)\s*\('
    },
    'lua': {
        'class_pattern': r'\b(\w+)\s*=\s*\{\}',
        'func_pattern': r'\bfunction\s+([\w.:]+)',
        'call_pattern': r'\b([\w.:]+)\s*\('
    },
    'javascript': {
        'class_pattern': r'\bclass\s+(\w+)',
        'func_pattern': r'\b(?:function\s+(\w+)|(\w+)\s*=\s*(?:\([^)]*\)|[^\s=]+)\s*=>|const\s+(\w+)\s*=\s*function)',
        'call_pattern': r'\b(\w+)\s*\('
    },
    'typescript': {
        'class_pattern': r'\b(?:class|interface|type)\s+(\w+)',
        'func_pattern': r'\b(?:function\s+(\w+)|(\w+)\s*=\s*(?:\([^)]*\)|[^\s=]+)\s*=>|const\s+(\w+)\s*=\s*function)',
        'call_pattern': r'\b(\w+)\s*\('
    },
    'cpp': {
        'class_pattern': r'\b(?:class|struct)\s+(\w+)',
        'func_pattern': r'\b\w+(?:<[^>]+>)?\s+(\w+)\s*\([^)]*\)\s*\{',
        'call_pattern': r'\b(\w+)\s*\('
    },
    'c': {
        'class_pattern': r'\bstruct\s+(\w+)',
