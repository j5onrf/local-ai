def analyze_generic_file(filepath):
    ext = os.path.splitext(filepath)[1].lstrip('.').lower() or "file"
    if is_binary(filepath): return {"type": f"binary/{ext}"}
    return {"type": ext, "summary": get_file_summary(filepath, 15) or "Empty file"}

# --- SQLITE-VEC HELPER FUNCTIONS ---
def load_vec_extension(conn):
    if not HAS_VEC:
        return False
    try:
        conn.enable_load_extension(True)
        sqlite_vec.load(conn)
        conn.enable_load_extension(False)
        return True
    except Exception as e:
        sys.stderr.write(f"\033[90m[sys] Warning: Failed to load sqlite-vec: {e}\033[0m\n")
        return False

def get_embedding(text, server_url=EMBEDDING_SERVER):
    text = text.replace("\n", " ").strip()[:3000]
    if not text:
        return None
    try:
        payload = {"input": text, "model": "text-embedding-ada-002"}
        req = urlreq.Request(
            f"{server_url}/v1/embeddings",
            data=json.dumps(payload).encode("utf-8"),
            headers={"Content-Type": "application/json"},
            method="POST"
        )
        with urlreq.urlopen(req, timeout=3) as res:
            data = json.loads(res.read().decode("utf-8"))
            return data["data"][0]["embedding"]
    except Exception:
        return None

def detect_embedding_dim(server_url=EMBEDDING_SERVER):
    emb = get_embedding("test", server_url)
    return len(emb) if emb else 384

def serialize_vec(vector):
    """Serializes a float array into direct binary bytes for sqlite-vec execution."""
    return struct.pack(f"{len(vector)}f", *vector)

# --- DATABASE MANAGEMENT & GRAPH BUILDING ---
def init_db(db_path, use_vec=False, dim=384):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    
    # 1. Load the vector extension FIRST so SQLite recognizes the vec0 module
    vec_loaded = False
    if use_vec:
        vec_loaded = load_vec_extension(conn)
        
    cursor.execute("DROP TABLE IF EXISTS edges")
    cursor.execute("DROP TABLE IF EXISTS nodes")
    
    # 2. Only attempt to drop the virtual table if the module is loaded
    if vec_loaded:
        cursor.execute("DROP TABLE IF EXISTS nodes_vec")
        
    cursor.execute("""
    CREATE TABLE nodes (
        id TEXT PRIMARY KEY,
        name TEXT NOT NULL,
        type TEXT NOT NULL,
        filepath TEXT NOT NULL,
        language TEXT,
        meta TEXT
    )""")
    cursor.execute("""
    CREATE TABLE edges (
        source TEXT,
        target TEXT,
        type TEXT NOT NULL,
        PRIMARY KEY (source, target, type),
        FOREIGN KEY (source) REFERENCES nodes(id) ON DELETE CASCADE,
        FOREIGN KEY (target) REFERENCES nodes(id) ON DELETE CASCADE
    )""")
    cursor.execute("CREATE INDEX idx_nodes_name ON nodes(name)")
    cursor.execute("CREATE INDEX idx_nodes_type ON nodes(type)")
    cursor.execute("CREATE INDEX idx_edges_source ON edges(source)")
    cursor.execute("CREATE INDEX idx_edges_target ON edges(target)")
    
    # 3. Create virtual table if loaded
    if vec_loaded:
        cursor.execute(f"""
        CREATE VIRTUAL TABLE nodes_vec USING vec0(
            id INTEGER PRIMARY KEY,
            embedding float[{dim}]
        )""")
            
    conn.commit()
    return conn, vec_loaded

def find_db_path(start_dir=None):
    if not start_dir: start_dir = os.getcwd()
    curr = os.path.abspath(start_dir)
    while True:
        for f in os.listdir(curr):
            if f.startswith("index-map-memory-") and f.endswith(".db"):
                return os.path.join(curr, f)
        parent = os.path.dirname(curr)
        if parent == curr: break
        curr = parent
    return None

def insert_node(conn, node_id, name, ntype, filepath, lang, meta_dict, text_to_embed, use_vec, server_url):
    cursor = conn.cursor()
    cursor.execute("INSERT OR REPLACE INTO nodes VALUES (?, ?, ?, ?, ?, ?)", 
                    (node_id, name, ntype, filepath, lang, json.dumps(meta_dict)))
    
    if use_vec and text_to_embed:
        rowid = cursor.lastrowid
        emb = get_embedding(text_to_embed, server_url)
        if emb:
            try:
                cursor.execute("INSERT INTO nodes_vec(id, embedding) VALUES (?, ?)", 
                                (rowid, serialize_vec(emb)))
            except Exception as e:
                sys.stderr.write(f"\033[90m[sys] Vector write failed on row {rowid}: {e}\033[0m\n")

# --- CONSOLIDATED STRUCTURAL WRITE HELPER (DEDUPLICATED) ---
def _commit_structures_to_db(db_conn, rel_path, ext_label, classes, functions, file_lines, use_vec):
    """Consolidated structure-node inserter for classes and functions across all languages."""
    for name, start, end in classes:
        class_id = f"class:{rel_path}:{name}"
        code = "\n".join(file_lines[max(0, start-1):end]).strip() if file_lines else ""
        insert_node(db_conn, class_id, name, 'class', rel_path, ext_label, 
                    {'line_start': start, 'line_end': end}, code, use_vec, EMBEDDING_SERVER)
        db_conn.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (f"file:{rel_path}", class_id, 'contains'))
        
    for name, parent_class, start, end, args in functions:
        func_id = f"func:{rel_path}:{parent_class}:{name}" if parent_class else f"func:{rel_path}:{name}"
        code = "\n".join(file_lines[max(0, start-1):end]).strip() if file_lines else ""
        insert_node(db_conn, func_id, name, 'function', rel_path, ext_label, 
                    {'line_start': start, 'line_end': end, 'args': args}, code, use_vec, EMBEDDING_SERVER)
        
        container = f"class:{rel_path}:{parent_class}" if parent_class else f"file:{rel_path}"
        db_conn.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (container, func_id, 'contains'))

# --- CORE ALGORITHM: RESOLVING EXPLICIT AND HEURISTIC DEPENDENCIES ---
def resolve_and_insert_edges(conn, raw_calls, file_imports):
    cursor = conn.cursor()
    cursor.execute("SELECT id, name, type, filepath FROM nodes WHERE type IN ('function', 'class')")
    all_targets = cursor.fetchall()
    
    target_map = {}
    for tid, name, ntype, filepath in all_targets:
        target_map.setdefault(name, []).append((tid, filepath, ntype))
        
    edges_to_insert = []
    for filepath, calls in raw_calls.items():
        imports = file_imports.get(filepath, [])
        import_names = {imp_as: full_name for full_name, imp_as in imports}
        
        for caller_func, caller_class, callee_name, line in calls:
            caller_id = f"func:{filepath}:{caller_class}:{caller_func}" if caller_class else f"func:{filepath}:{caller_func}"
            resolved_target = None
            candidates = target_map.get(callee_name, [])
            
            # Scenario A: Candidate defined in same file
            local_cand = [c for c in candidates if c[1] == filepath]
            if local_cand:
                resolved_target = local_cand[0][0]
                
            # Scenario B: Target matches local module imports
            if not resolved_target and callee_name in import_names:
                full_import_name = import_names[callee_name]
                import_cand_name = full_import_name.split('.')[-1]
                cands_for_import = target_map.get(import_cand_name, [])
                if cands_for_import:
                    resolved_target = cands_for_import[0][0]
                    
            # Scenario C: Globally unique match
            if not resolved_target and len(candidates) == 1:
                resolved_target = candidates[0][0]
                
            # Scenario D: Multiple matches: draw edges to all possible paths to ensure blast-radius stability
            if not resolved_target and len(candidates) > 1:
                for cand_id, _, _ in candidates:
                    edges_to_insert.append((caller_id, cand_id, 'calls'))
                continue
                
            if resolved_target:
                edges_to_insert.append((caller_id, resolved_target, 'calls'))
                
    try:
        # High-speed batch sqlite executemany replaces slower looping evaluations
        cursor.executemany("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", edges_to_insert)
    except Exception:
        pass
    conn.commit()

# --- ASCII TREE BUILDER ---
def compile_ascii_tree(target_dir: str) -> str:
    files_to_check = []
    # Compact directory scanner loop
    for root in (target_dir, os.path.join(target_dir, "modules")):
        if os.path.isdir(root):
            sub = "modules" if "modules" in root else ""
            files_to_check.extend((sub, f, os.path.join(root, f)) for f in sorted(os.listdir(root)) if os.path.isfile(os.path.join(root, f)))
            
    if not files_to_check: return ""
    lines = ["# Codebase Modules & Active Architecture:"]
    total = len(files_to_check)
    for idx, (subdir, name, path) in enumerate(files_to_check):
        display_name = os.path.join(subdir, name) if subdir else name
        desc = get_file_summary(path)
        connector = "└── " if idx == total - 1 else "├── "
        lines.append(f"#   {connector}{display_name:<24} - {desc}" if desc else f"#   {connector}{display_name}")
    return "\n".join(lines) + "\n# -----------------------------------------------------------------------------------------\n"

# --- COMPRESSED SHORTHAND COMPILER ---
def compile_flat_shorthand(skeleton):
    lines = []
    for rel_path, data in sorted(skeleton.items()):
        t = data.get("type", "file")
        meta_parts = []
        
        if t == "python":
            meta_parts = [
                f"imp:{','.join(data['imports'])}" if data.get('imports') else "",
                f"cls:{','.join(data['classes'])}" if data.get('classes') else "",
                f"fn:{','.join(data['functions'])}" if data.get('functions') else ""
            ]
        elif t in ("rust", "go", "lua", "qml"):
            meta_parts = [
                f"cls:{','.join(data['classes'])}" if data.get('classes') else "",
                f"fn:{','.join(data['functions'])}" if data.get('functions') else ""
            ]
        elif t == "markdown":
            meta_parts = [
                f"title:{data['title']}" if data.get('title') else "",
                f"tags:{','.join(data['tags'])}" if data.get('tags') else "",
                f"links:{','.join(data['links'])}" if data.get('links') else ""
            ]
        elif t.startswith("image/"):
            meta_parts = [
                f"dim:{data['dim']}" if data.get('dim') else "",
                f"size:{data['size']}" if data.get('size') else ""
            ]
        elif t == "json":
            meta_parts = [f"keys:{','.join(data['keys'])}" if data.get('keys') else ""]
        else:
            summary = data.get("summary", "").replace("\n", " ").strip()
            meta_parts = [f"sum:{summary}" if summary else ""]
            
        meta = " | ".join(filter(None, meta_parts))
        lines.append(f"[{t}:{rel_path}] {meta}" if meta else f"[{t}:{rel_path}]")
    return "\n".join(lines)

# --- CORE INDEXER ---
def run_indexing(target_dir, force=False):
    is_interactive = sys.stdin.isatty() and sys.stderr.isatty()
    if is_interactive and not force:
        try:
            sys.stderr.write("\r\x1b[2K\033[2mℹ Mapping workspace... [Confirming compile]\033[0m")
            sys.stderr.flush()
            key = get_key()
            if key in ('\x03', '\x1b', 'n', 'N'):
                sys.stderr.write("\r\x1b[2K\033[2;31m[sys] Bypassed mapping execution.\033[0m\n")
                sys.stderr.flush(); safe_exit(0)
            sys.stderr.write("\r\x1b[2K"); sys.stderr.flush()
        except: pass

    if target_dir == os.path.expanduser("~"):
        try:
            sys.stderr.write("\n\033[1;33m[sys] Warning: Scanning entire Home Directory. Proceed? (y/N): \033[0m"); sys.stderr.flush()
            if sys.stdin.readline().strip().lower() not in ['y', 'yes']: safe_exit(0)
        except: safe_exit(0)

    # 1. Establish SQLite Database Connections
    proj_name = os.path.basename(target_dir)
    db_path = os.path.join(target_dir, f"index-map-memory-{proj_name}.db")
    
    # Check if local embedding model server is active and get model dimensions
    use_vec = HAS_VEC
    embedding_dim = 384
    if use_vec:
        sys.stderr.write("\r\x1b[2K\033[2mℹ Mapping workspace... [Probing local embedding server]\033[0m")
        sys.stderr.flush()
        detected_dim = detect_embedding_dim(EMBEDDING_SERVER)
        if detected_dim:
            embedding_dim = detected_dim
            sys.stderr.write(f"\r\x1b[2K\033[2mℹ Mapping workspace... [Embedding server found ({embedding_dim} dim)]\033[0m")
            sys.stderr.flush()
        else:
            use_vec = False
            sys.stderr.write("\r\x1b[2K\033[2mℹ Mapping workspace... [Embedding server offline. Using relational graph only]\033[0m")
            sys.stderr.flush()
            time.sleep(0.6) # Slight pause so warning can be read
            
    sys.stderr.write("\r\x1b[2K\033[2mℹ Mapping workspace... [Compiling relational index graph]\033[0m")
    sys.stderr.flush()
    db_conn, use_vec = init_db(db_path, use_vec=use_vec, dim=embedding_dim)
    
    default_ignored = {
        '.git', '__pycache__', 'logs', '.auto-f', 'node_modules', 
        'venv', '.venv', 'SSD_BACKUPS', '.cargo', '.rustup', 
        '.cache', '.npm', '.local', '.mozilla', 'target'
    }
    patterns = load_gitignore_patterns(target_dir)
    
    skeleton = {}
    raw_calls = {}
    file_imports = {}
    
    file_count = 0
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not should_ignore(os.path.relpath(os.path.join(root, d), target_dir), True, patterns, default_ignored)]
        for file in files:
            filepath = os.path.join(root, file)
            rel_path = os.path.relpath(filepath, target_dir)
            if should_ignore(rel_path, False, patterns, default_ignored): continue
            
            file_count += 1
            if file_count == 1000:
                sys.stderr.write(f"\n\033[1;33m[sys] Warning: Scanned 1,000 files. Proceed? (y/N): \033[0m"); sys.stderr.flush()
                try:
                    if sys.stdin.readline().strip().lower() not in ['y', 'yes']: safe_exit(0)
                except: safe_exit(0)
                
            ext = os.path.splitext(file)[1].lower()
            
            # File Node Registration
            insert_node(db_conn, f"file:{rel_path}", rel_path, 'file', rel_path, ext.lstrip('.'), {}, rel_path, use_vec, EMBEDDING_SERVER)
            
            if ext == '.py':
                try:
                    with open(filepath, 'r', encoding='utf-8', errors='replace') as f: content = f.read()
                    lines = content.splitlines()
                    with warnings.catch_warnings():
                        warnings.simplefilter("ignore", SyntaxWarning)
                        tree = ast.parse(content, filename=filepath)
                    visitor = PythonGraphVisitor(rel_path)
                    visitor.visit(tree)
                    
                    # Store variables for resolution pass
                    raw_calls[rel_path] = visitor.calls
                    file_imports[rel_path] = visitor.imports
                    
                    # Map to skeleton formatting for flat file backward compatibility
                    skeleton[rel_path] = {
                        "type": "python",
                        "imports": sorted(list({i[0].split('.')[0] for i in visitor.imports})),
                        "classes": [c[0] for c in visitor.classes],
                        "functions": [f[0] for f in visitor.functions]
                    }
                    
                    # Store Python structure directly to DB
                    _commit_structures_to_db(db_conn, rel_path, 'python', visitor.classes, visitor.functions, lines, use_vec)
                except Exception as e:
                    skeleton[rel_path] = {"type": "python", "error": f"AST error: {e}"}
                    
            elif ext in ('.rs', '.go', '.lua', '.js', '.ts', '.cpp', '.hpp', '.c', '.h'):
                parsed = parse_non_python_file(filepath, ext)
                raw_calls[rel_path] = parsed['calls']
                
                try:
                    with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
                        file_lines = f.read().splitlines()
                except Exception:
                    file_lines = []
                
                skeleton[rel_path] = {
                    "type": ext.lstrip('.'),
                    "classes": [c[0] for c in parsed['classes']],
                    "functions": [f[0] for f in parsed['functions']]
                }
                
                # Store multi-language structure directly to DB
                _commit_structures_to_db(db_conn, rel_path, ext.lstrip('.'), parsed['classes'], parsed['functions'], file_lines, use_vec)
            else:
                dispatch = {
                    '.md': analyze_markdown_file, '.sh': analyze_shell_file, '.bash': analyze_shell_file,
                    '.json': analyze_json_file, '.qml': analyze_qml_file, '.png': analyze_image_file, 
                    '.jpg': analyze_image_file, '.jpeg': analyze_image_file, '.gif': analyze_image_file, '.svg': analyze_image_file
                }
                skeleton[rel_path] = dispatch.get(ext, analyze_generic_file)(filepath)
                
    db_conn.commit()
    resolve_and_insert_edges(db_conn, raw_calls, file_imports)
    db_conn.close()
    
    flat_map = compile_flat_shorthand(skeleton)
    
    display_dir = target_dir
    home_dir = os.path.expanduser("~")
    if display_dir.startswith(home_dir):
        display_dir = display_dir.replace(home_dir, "~", 1)
        
    date_str = time.strftime('%Y-%m-%d %H:%M')
    
# ADVANCED CODE INTELLIGENCE SYSTEM INDEX MAP
    header = (
        f"# CODEBASE INDEX MAP | Generated: {date_str} | Workspace: {proj_name} | Path: {display_dir}\n"
        f"# Active symbols and structural connections mapped in the local SQLite graph DB.\n"
        f"# Intents: trace symbol <sym> | blast radius <sym> | read function <sym> | find symbol <pat> | architecture overview\n"
        f"# -----------------------------------------------------------------------------------------\n"
    )
    
    architecture_tree = compile_ascii_tree(target_dir)
    if architecture_tree: header += architecture_tree
    else: header += "# -----------------------------------------------------------------------------------------\n\n"
        
    flat_map = header + flat_map
    output_file = os.path.join(target_dir, f"index-map-{proj_name}.txt")
    
    try:
        with open(output_file, 'w', encoding='utf-8') as f: fill = f.write(flat_map)
        # Overwrite the progress line with a single, clean, 1-line confirmation
        sys.stderr.write(f"\r\x1b[2K\033[1;32m✔ Mapping complete! [{proj_name} index-map & SQLite graph database updated]\033[0m\n")
        sys.stderr.flush()
    except Exception as e:
        sys.stderr.write(f"\r\x1b[2K\033[1;31m❌ Error: Failed to write output files: {e}\033[0m\n")
        sys.stderr.flush()

