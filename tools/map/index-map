# --- QUERY TOOL: SYMBOL TRACING (CALLERS & CALLEES) ---
def trace_symbol(symbol):
    db = find_db_path()
    if not db:
        print("❌ Database not found. Initialize first.")
        return
    conn = sqlite3.connect(db)
    cursor = conn.cursor()
    
    cursor.execute("SELECT id, type, filepath FROM nodes WHERE name = ?", (symbol,))
    nodes = cursor.fetchall()
    if not nodes:
        print(f"❌ Symbol '{symbol}' was not found in the relationship map.")
        conn.close(); return
        
    for node_id, node_type, filepath in nodes:
        print(f"\n\033[1;34m[Trace Call Tree] For: {symbol} ({node_type}) in {filepath}\033[0m")
        
        # Upstream callers
        print("\n\033[1;32m◀── [Callers] (Who invokes/uses this symbol):\033[0m")
        cursor.execute("SELECT source FROM edges WHERE target = ? AND type = 'calls'", (node_id,))
        callers = cursor.fetchall()
        if not callers: print("  (None detected)")
        for (caller,) in callers:
            parts = caller.split(":")
            print(f"  ├── \033[36m{parts[-1]}\033[0m [{parts[0]}] ({parts[1]})")
            
        # Downstream callees
        print("\n\033[1;35m──▶ [Callees] (Who/What this symbol calls):\033[0m")
        cursor.execute("SELECT target FROM edges WHERE source = ? AND type = 'calls'", (node_id,))
        callees = cursor.fetchall()
        if not callees: print("  (None detected)")
        for (callee,) in callees:
            parts = callee.split(":")
            print(f"  ├── \033[36m{parts[-1]}\033[0m [{parts[0]}] ({parts[1]})")
    conn.close()

# --- QUERY TOOL: RECURSIVE BLAST-RADIUS ANALYSIS ---
def get_blast_radius(symbol):
    db = find_db_path()
    if not db:
        print("❌ Database not found."); return
    conn = sqlite3.connect(db)
    cursor = conn.cursor()
    
    cursor.execute("SELECT id, type, filepath FROM nodes WHERE name = ?", (symbol,))
    starts = cursor.fetchall()
    if not starts:
        print(f"❌ Symbol '{symbol}' not found."); conn.close(); return
        
    for node_id, node_type, filepath in starts:
        print(f"\n\033[1;31m[Blast Radius] Upstream structural impact map for modifying: {symbol}\033[0m")
        print(f"📍 Target Anchor: {node_id} ({node_type})")
        
        visited = {node_id}
        queue = [(node_id, 0)]
        levels = {}
        
        while queue:
            curr, lvl = queue.pop(0)
            if lvl > 0:
                levels.setdefault(lvl, []).append(curr)
            if lvl >= 5: continue  # safety gate recursion depth limit
            
            cursor.execute("SELECT source FROM edges WHERE target = ? AND type IN ('calls', 'contains')", (curr,))
            for (source,) in cursor.fetchall():
                if source not in visited:
                    visited.add(source)
                    queue.append((source, lvl + 1))
                    
        if not levels:
            print("  ↳ \033[32mNo upstream dependencies detected. Low risk index block.\033[0m")
        else:
            for lvl in sorted(levels.keys()):
                indent = "  " * lvl
                color = "\033[1;33m" if lvl == 1 else "\033[33m"
                header_lbl = "Direct Impact (Callers/Containers):" if lvl == 1 else "Indirect Transitive Impact:"
                print(f"{indent}↳ Level {lvl} {header_lbl}")
                for item in levels[lvl]:
                    parts = item.split(":")
                    print(f"{indent}  - {color}{parts[-1]}\033[0m [{parts[0]}] ({parts[1]})")
    conn.close()

# --- QUERY TOOL: CODE SNIPPET EXTRACTOR ---
def extract_snippet(symbol):
    db = find_db_path()
    if not db:
        print("❌ Database not found."); return
    conn = sqlite3.connect(db)
    cursor = conn.cursor()
    cursor.execute("SELECT filepath, meta, type FROM nodes WHERE name = ?", (symbol,))
    results = cursor.fetchall()
    if not results:
        print(f"❌ Symbol '{symbol}' not found."); conn.close(); return
        
    # Find active working folder
    root_dir = os.path.dirname(db)
    for filepath, meta_str, node_type in results:
        meta = json.loads(meta_str) if meta_str else {}
        l_start = meta.get('line_start')
        l_end = meta.get('line_end')
        
        full_path = os.path.join(root_dir, filepath)
        if not os.path.isfile(full_path):
            print(f"❌ Target path does not exist on disk: {filepath}"); continue
            
        print(f"\n\033[1;36m[Snippet] {node_type.upper()} {symbol} in {filepath} (Lines {l_start} to {l_end}):\033[0m")
        if l_start and l_end:
            try:
                with open(full_path, 'r', encoding='utf-8', errors='ignore') as f:
                    lines = f.readlines()
                print("".join(lines[max(0, l_start-1):l_end]))
            except Exception as e:
                print(f"❌ Snippet extract read failure: {e}")
        else:
            print("  (Offsets were not cached for this node structure)")
    conn.close()

# --- CUSTOM CYPHER-LIKE DIRECT SQL CONSOLE ---
def run_custom_query(sql_str):
    db = find_db_path()
    if not db:
        print("❌ Database not found."); return
    conn = sqlite3.connect(db)
    cursor = conn.cursor()
    try:
        cursor.execute(sql_str)
        headers = [d[0] for d in cursor.description] if cursor.description else []
        rows = cursor.fetchall()
        print(f"\n\033[1;32m[SQL Results: {len(rows)} rows matched]\033[0m")
        if headers:
            print(" | ".join(f"\033[1;34m{h}\033[0m" for h in headers))
            print("-" * (len(" | ".join(headers)) + 5))
        for row in rows:
            print(" | ".join(str(val) for val in row))
    except Exception as e:
        print(f"❌ SQL Syntax Execution Error: {e}")
    conn.close()

# --- CLI ARGUMENT ROUTING ---
def main():
    args = sys.argv[1:]
    
    if len(args) == 0:
        run_indexing(os.getcwd())
        return
        
    cmd = args[0].lower()
    
    if cmd in ("--force", "-f"):
        run_indexing(os.getcwd(), force=True)
    elif cmd in ("--help", "-h"):
        print("""
Usage: index-map-memory.py <command> [argument]

Commands:
  (no arguments)        Interactive initialization & map compiler in local directory
  init [dir]            Initializes and builds the SQLite database + flat tag shorthand
  architecture          Visualizes core architectural connections and metadata counts
  search <pattern>      Searches database entries matching symbol queries
  trace <symbol>        Traces callers (upstream) and callees (downstream) for a symbol
  blast-radius <symbol> Traces recursively what dependencies will be broken if changed
  snippet <symbol>      Statically loads structural code blocks directly via offsets
  query "<SQL>"         Executes low-level queries directly against the graph schema
        """)
    elif cmd == "init":
        t_dir = os.path.abspath(os.path.expanduser(args[1])) if len(args) > 1 else os.getcwd()
        if not os.path.isdir(t_dir): os.makedirs(t_dir, exist_ok=True)
        run_indexing(t_dir)
    elif cmd == "architecture":
        show_architecture()
    elif cmd == "search":
        if len(args) < 2:
            print("❌ Must provide a search pattern."); return
        db = find_db_path()
        if not db: print("❌ Database not found."); return
        conn = sqlite3.connect(db)
        cursor = conn.cursor()
        cursor.execute("SELECT id, type, filepath FROM nodes WHERE name LIKE ? LIMIT 50", (f"%{args[1]}%",))
        res = cursor.fetchall()
        print(f"\n\033[1;32m[Matches Found: {len(res)}]\033[0m")
        for rid, rtype, rpath in res:
            print(f"  - \033[1;36m{rid}\033[0m [{rtype}] ({rpath})")
        conn.close()
    elif cmd == "trace":
        if len(args) < 2: print("❌ Must specify a class or function symbol."); return
        trace_symbol(args[1])
    elif cmd == "blast-radius":
        if len(args) < 2: print("❌ Must specify target symbol to evaluate."); return
        get_blast_radius(args[1])
    elif cmd == "snippet":
        if len(args) < 2: print("❌ Must specify symbol name."); return
        extract_snippet(args[1])
    elif cmd == "query":
        if len(args) < 2: print("❌ Must specify SQLite query string wrapped in quotes."); return
        run_custom_query(args[1])
    else:
        path_test = os.path.abspath(os.path.expanduser(args[0]))
        if os.path.isdir(path_test):
            run_indexing(path_test, force=("--force" in args))
        else:
            print(f"❌ Unknown command or folder: {args[0]}. Run with --help for documentation.")

if __name__ == "__main__":
    main()
