                    }
                    
                    # Store structures into local SQLite Nodes & Structural Containment Edges
                    for c_name, c_start, c_end in visitor.classes:
                        class_id = f"class:{rel_path}:{c_name}"
                        db_conn.execute("INSERT OR REPLACE INTO nodes VALUES (?, ?, ?, ?, ?, ?)", 
                                        (class_id, c_name, 'class', rel_path, 'python', json.dumps({'line_start': c_start, 'line_end': c_end})))
                        db_conn.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (f"file:{rel_path}", class_id, 'contains'))
                        
                    for f_name, parent_class, f_start, f_end, f_args in visitor.functions:
                        func_id = f"func:{rel_path}:{parent_class}:{f_name}" if parent_class else f"func:{rel_path}:{f_name}"
                        db_conn.execute("INSERT OR REPLACE INTO nodes VALUES (?, ?, ?, ?, ?, ?)", 
                                        (func_id, f_name, 'function', rel_path, 'python', json.dumps({'line_start': f_start, 'line_end': f_end, 'args': f_args})))
                        
                        container_id = f"class:{rel_path}:{parent_class}" if parent_class else f"file:{rel_path}"
                        db_conn.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (container_id, func_id, 'contains'))
                except Exception as e:
                    skeleton[rel_path] = {"type": "python", "error": f"AST error: {e}"}
                    
            elif ext in ('.rs', '.go', '.lua', '.js', '.ts', '.cpp', '.hpp', '.c', '.h'):
                parsed = parse_non_python_file(filepath, ext)
                raw_calls[rel_path] = parsed['calls']
                
                skeleton[rel_path] = {
                    "type": ext.lstrip('.'),
                    "classes": [c[0] for c in parsed['classes']],
                    "functions": [f[0] for f in parsed['functions']]
                }
                
                for c_name, c_start, c_end in parsed['classes']:
                    class_id = f"class:{rel_path}:{c_name}"
                    db_conn.execute("INSERT OR REPLACE INTO nodes VALUES (?, ?, ?, ?, ?, ?)", 
                                    (class_id, c_name, 'class', rel_path, ext.lstrip('.'), json.dumps({'line_start': c_start, 'line_end': c_end})))
                    db_conn.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (f"file:{rel_path}", class_id, 'contains'))
                    
                for f_name, parent_class, f_start, f_end, f_args in parsed['functions']:
                    func_id = f"func:{rel_path}:{parent_class}:{f_name}" if parent_class else f"func:{rel_path}:{f_name}"
                    db_conn.execute("INSERT OR REPLACE INTO nodes VALUES (?, ?, ?, ?, ?, ?)", 
                                    (func_id, f_name, 'function', rel_path, ext.lstrip('.'), json.dumps({'line_start': f_start, 'line_end': f_end, 'args': f_args})))
                    
                    container_id = f"class:{rel_path}:{parent_class}" if parent_class else f"file:{rel_path}"
