        'call_pattern': r'\b(\w+)\s*\('
    }
}

# --- SYSTEM UTILS ---
def safe_exit(code=0):
    try: sys.stdout.flush(); sys.stderr.flush()
    except: pass
    try: sys.stdout, sys.stderr = open(os.devnull, 'w'), open(os.devnull, 'w')
    except: pass
    sys.exit(code)

def get_key():
    try:
        import tty, termios, select
    except ImportError:
        try: return sys.stdin.read(1)
        except: return ""
    fd = sys.stdin.fileno()
    try: old = termios.tcgetattr(fd)
    except termios.error:
        try: return os.read(fd, 1).decode("utf-8", errors="ignore")
        except: return ""
    try:
        tty.setraw(fd); r = os.read(fd, 1)
        if r == b'\x1b' and select.select([fd], [], [], 0.05)[0]: r += os.read(fd, 2)
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)
    return r.decode("utf-8", errors="ignore")

def load_gitignore_patterns(target_dir):
    path = os.path.join(target_dir, ".gitignore")
    if os.path.isfile(path):
        try:
            with open(path, 'r', encoding='utf-8', errors='ignore') as f:
                return [line.strip() for line in f if line.strip() and not line.strip().startswith(('#', '!'))]
        except Exception: pass
    return []

def should_ignore(rel_path, is_dir, gitignore_patterns, default_ignored_dirs):
    norm_path = rel_path.replace(os.sep, '/')
    parts = norm_path.split('/')
    if any(p in default_ignored_dirs for p in parts): return True
    
    for pattern in gitignore_patterns:
        pat, dir_only = pattern.rstrip('/'), pattern.endswith('/')
        if dir_only and not is_dir: continue
        
        anchored = False
        if pat.startswith('/'): pat, anchored = pat[1:], True
        
        if anchored:
            target = norm_path if not dir_only else norm_path.rstrip('/')
            if fnmatch.fnmatchcase(target, pat): return True
            pat_parts = pat.split('/')
            if len(parts) >= len(pat_parts) and fnmatch.fnmatchcase('/'.join(parts[:len(pat_parts)]), pat):
                return True
        else:
            for i, part in enumerate(parts):
                if dir_only and i == len(parts) - 1 and not is_dir: continue
                if fnmatch.fnmatchcase(part, pat): return True
                if '/' in pat:
                    p_len = len(pat.split('/'))
                    for j in range(len(parts) - p_len + 1):
                        if fnmatch.fnmatchcase('/'.join(parts[j:j+p_len]), pat): return True
    return False

def is_binary(filepath):
    try:
        with open(filepath, 'rb') as f: return b'\x00' in f.read(1024)
    except Exception: return True

def get_text_summary(filepath, limit=15, is_shell=False, strip_hash=True):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            for _ in range(limit):
                line = f.readline()
                if not line: break
                stripped = line.strip()
                if not stripped or (is_shell and stripped.startswith('#!')): continue
                if not strip_hash: return stripped[:120]
                if stripped.startswith('#'): return stripped.lstrip('# ').strip()[:120]
                if not is_shell: return stripped[:120]
        return ""
    except: return ""

def extract_file_description(filepath: str) -> str:
    if not os.path.isfile(filepath) or is_binary(filepath): return ""
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            lines = [f.readline().strip() for _ in range(3)]
        for line in lines:
            if not line or line.startswith("#!"): continue
            if line.startswith("#") or line.startswith("//"):
                cleaned = line.lstrip("#/ \t").strip()
                if cleaned.lower().startswith("file:") or "path:" in cleaned.lower(): continue
                return cleaned[:100]
        return ""
    except Exception: return ""

# --- AST VISITOR FOR PYTHON SYMBOLS & INTERNAL CALLS ---
class PythonGraphVisitor(ast.NodeVisitor):
    def __init__(self, filepath):
        self.filepath = filepath
        self.classes = []  # (name, start_line, end_line)
        self.functions = []  # (name, parent_class, start_line, end_line, args)
        self.calls = []  # (caller_func, caller_class, callee, line)
        self.imports = []  # (module_full_name, imported_as_name)
        self.current_class = None
        self.current_function = None

    def visit_Import(self, node):
        for alias in node.names:
            self.imports.append((alias.name, alias.asname or alias.name))
        self.generic_visit(node)

    def visit_ImportFrom(self, node):
        if node.module:
            for alias in node.names:
                self.imports.append((f"{node.module}.{alias.name}", alias.asname or alias.name))
        self.generic_visit(node)

    def visit_ClassDef(self, node):
        prev_class = self.current_class
        self.current_class = node.name
        end_line = getattr(node, 'end_lineno', node.lineno)
        self.classes.append((node.name, node.lineno, end_line))
        self.generic_visit(node)
        self.current_class = prev_class

    def visit_FunctionDef(self, node):
        self.visit_any_func(node)

    def visit_AsyncFunctionDef(self, node):
        self.visit_any_func(node)

    def visit_any_func(self, node):
        prev_func = self.current_function
        self.current_function = node.name
        end_line = getattr(node, 'end_lineno', node.lineno)
        args_list = [arg.arg for arg in node.args.args]
        self.functions.append((node.name, self.current_class, node.lineno, end_line, args_list))
        self.generic_visit(node)
        self.current_function = prev_func

    def visit_Call(self, node):
        if self.current_function:
            callee = None
            if isinstance(node.func, ast.Name):
                callee = node.func.id
            elif isinstance(node.func, ast.Attribute):
                callee = node.func.attr
            if callee:
                self.calls.append((self.current_function, self.current_class, callee, node.lineno))
        self.generic_visit(node)

# --- HYBRID REGEX-BASED MULTI-LANGUAGE PARSER ---
def parse_non_python_file(filepath, ext):
    lang = {
        '.rs': 'rust', '.go': 'go', '.lua': 'lua',
        '.js': 'javascript', '.ts': 'typescript',
        '.cpp': 'cpp', '.hpp': 'cpp', '.c': 'c', '.h': 'c'
    }.get(ext)
    
    empty_result = {'classes': [], 'functions': [], 'calls': [], 'imports': []}
    if not lang or lang not in LANG_RULES:
        return empty_result
        
    rules = LANG_RULES[lang]
    classes, functions, calls = [], [], []
    
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f:
            lines = f.readlines()
    except Exception:
        return empty_result
        
    current_class, current_func = None, None
    for idx, line in enumerate(lines, 1):
        clean_line = line.strip()
        if not clean_line or clean_line.startswith('//') or clean_line.startswith('/*') or clean_line.startswith('--') or clean_line.startswith('#'):
            continue
            
        class_match = re.search(rules['class_pattern'], clean_line)
        if class_match:
            current_class = class_match.group(1)
            classes.append((current_class, idx, idx))
            
        func_match = re.search(rules['func_pattern'], clean_line)
        if func_match:
            if current_func and functions:
                functions[-1] = (functions[-1][0], functions[-1][1], functions[-1][2], idx - 1, [])
            func_name = next((g for g in func_match.groups() if g), None)
            if func_name:
                current_func = func_name
                functions.append((func_name, current_class, idx, idx, []))
                
        if current_func:
            call_matches = re.findall(rules['call_pattern'], clean_line)
            for callee in call_matches:
                if callee not in ('if', 'for', 'while', 'switch', 'return', 'fn', 'func', 'function', 'struct', 'class', 'let', 'const', 'var', 'import', 'require'):
                    if callee != current_func:
                        calls.append((current_func, current_class, callee, idx))
                        
    if current_func and functions:
        functions[-1] = (functions[-1][0], functions[-1][1], functions[-1][2], len(lines), [])
        
    return {'classes': classes, 'functions': functions, 'calls': calls, 'imports': []}

# --- EXTRACT STATIC METADATA ---
def analyze_markdown_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        title = ""
        tm = re.search(r'^#\s+(.*)', content, re.M)
        if tm: title = tm.group(1).strip()
        tags = set()
        fm_match = re.search(r'^---\s*\n(.*?)\n---\s*\n', content, re.DOTALL)
        if fm_match:
            fm_text = fm_match.group(1)
            tags_match = re.search(r'tags\s*:\s*[\[\']?([^\]\']+)\]?', fm_text, re.I)
            if tags_match:
                tags.update(t.strip().lower() for t in tags_match.group(1).split(',') if t.strip())
        links = set()
        for w in re.findall(r'\[\[([^#\]|]+)(?:#[^\]|]+)?(?:\|[^\]]+)?\]\]', content):
            links.add(w.strip())
        for ml in re.findall(r'\[[^\]]+\]\(([^)]+\.(?:md|txt|py|sh|rs|go|lua))\)', content):
            if not ml.startswith(("http", "https")):
                links.add(os.path.basename(ml))
        return {"type": "markdown", "title": title or os.path.splitext(os.path.basename(filepath))[0], "tags": sorted(list(tags)) if tags else [], "links": sorted(list(links)) if links else []}
    except Exception:
        return {"type": "markdown", "title": os.path.splitext(os.path.basename(filepath))[0]}

def analyze_image_file(filepath):
    ext = os.path.splitext(filepath)[1].lstrip('.').lower()
    size_bytes = os.path.getsize(filepath)
    size_str = f"{size_bytes / 1024:.1f}KB" if size_bytes < 1024*1024 else f"{size_bytes / (1024*1024):.1f}MB"
    try:
        with open(filepath, 'rb') as f: head = f.read(512)
        w, h = 0, 0
        if ext == "png" and head.startswith(b'\x89PNG\r\n\x1a\n'):
            import struct
            w, h = struct.unpack('>II', head[16:24])
        elif ext == "gif" and (head.startswith(b'GIF87a') or head.startswith(b'GIF89a')):
            import struct
            w, h = struct.unpack('<HH', head[6:10])
        elif ext in ("jpg", "jpeg") and head.startswith(b'\xff\xd8'):
            import struct
            f_idx = 2
            while f_idx < len(head):
                marker, length = struct.unpack('>HH', head[f_idx:f_idx+4])
                if 0xffc0 <= marker <= 0xffc3:
                    h, w = struct.unpack('>HH', head[f_idx+5:f_idx+9])
                    break
                f_idx += length + 2
        elif ext == "svg":
            text = head.decode("utf-8", errors="ignore")
            wm = re.search(r'width\s*=\s*["\']([^"\']+)["\']', text)
            hm = re.search(r'height\s*=\s*["\']([^"\']+)["\']', text)
            return {"type": "image/svg", "dim": f"{wm.group(1) if wm else ''}x{hm.group(1) if hm else ''}", "size": size_str}
        if w and h: return {"type": f"image/{ext}", "dim": f"{w}x{h}", "size": size_str}
        return {"type": f"image/{ext}", "size": size_str}
    except Exception:
        return {"type": f"image/{ext}", "size": size_str}

def analyze_json_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: data = json.load(f)
        return {"type": "json", "keys": list(data.keys()) if isinstance(data, dict) else []}
    except: return {"type": "json", "error": "Malformed JSON"}

def analyze_qml_file(filepath):
    try:
        with open(filepath, 'r', encoding='utf-8', errors='ignore') as f: content = f.read()
        content = re.sub(r'//.*|/\*.*?\*/', '', content, flags=re.DOTALL)
        return {"type": "qml", "properties": re.findall(r'\bproperty\s+\w+\s+(\w+)', content), "functions": re.findall(r'\bfunction\s+(\w+)', content)}
    except: return {"type": "qml", "error": "Unparseable"}

def analyze_shell_file(filepath):
    return {"type": "shell", "summary": get_text_summary(filepath, 10, True, True) or "Shell Module"}

def analyze_generic_file(filepath):
    ext = os.path.splitext(filepath)[1].lstrip('.').lower() or "file"
    if is_binary(filepath): return {"type": f"binary/{ext}"}
    return {"type": ext, "summary": get_text_summary(filepath, 15, False, False) or "Empty file"}

# --- DATABASE MANAGEMENT & GRAPH BUILDING ---
def init_db(db_path):
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute("DROP TABLE IF EXISTS edges")
    cursor.execute("DROP TABLE IF EXISTS nodes")
    cursor.execute("""
    CREATE TABLE nodes (
        id TEXT PRIMARY KEY,
        name TEXT NOT NULL,
        type TEXT NOT NULL,
        filepath TEXT NOT NULL,
        language TEXT,
        meta TEXT
    )""")
    cursor.execute("""
    CREATE TABLE edges (
        source TEXT,
        target TEXT,
        type TEXT NOT NULL,
        PRIMARY KEY (source, target, type),
        FOREIGN KEY (source) REFERENCES nodes(id) ON DELETE CASCADE,
        FOREIGN KEY (target) REFERENCES nodes(id) ON DELETE CASCADE
    )""")
    cursor.execute("CREATE INDEX idx_nodes_name ON nodes(name)")
    cursor.execute("CREATE INDEX idx_nodes_type ON nodes(type)")
    cursor.execute("CREATE INDEX idx_edges_source ON edges(source)")
    cursor.execute("CREATE INDEX idx_edges_target ON edges(target)")
    conn.commit()
    return conn

def find_db_path(start_dir=None):
    if not start_dir: start_dir = os.getcwd()
    curr = os.path.abspath(start_dir)
    while True:
        for f in os.listdir(curr):
            if f.startswith("index-map-memory-") and f.endswith(".db"):
                return os.path.join(curr, f)
        parent = os.path.dirname(curr)
        if parent == curr: break
        curr = parent
    return None

# --- CORE ALGORITHM: RESOLVING EXPLICIT AND HEURISTIC DEPENDENCIES ---
def resolve_and_insert_edges(conn, raw_calls, file_imports):
    cursor = conn.cursor()
    cursor.execute("SELECT id, name, type, filepath FROM nodes WHERE type IN ('function', 'class')")
    all_targets = cursor.fetchall()
    
    target_map = {}
    for tid, name, ntype, filepath in all_targets:
        if name not in target_map: target_map[name] = []
        target_map[name].append((tid, filepath, ntype))
        
    edges_to_insert = []
    for filepath, calls in raw_calls.items():
        imports = file_imports.get(filepath, [])
        import_names = {imp_as: full_name for full_name, imp_as in imports}
        
        for caller_func, caller_class, callee_name, line in calls:
            caller_id = f"func:{filepath}:{caller_class}:{caller_func}" if caller_class else f"func:{filepath}:{caller_func}"
            resolved_target = None
            candidates = target_map.get(callee_name, [])
            
            # Scenario A: Candidate defined in same file
            local_cand = [c for c in candidates if c[1] == filepath]
            if local_cand:
                resolved_target = local_cand[0][0]
                
            # Scenario B: Target matches local module imports
            if not resolved_target and callee_name in import_names:
                full_import_name = import_names[callee_name]
                import_cand_name = full_import_name.split('.')[-1]
                cands_for_import = target_map.get(import_cand_name, [])
                if cands_for_import:
                    resolved_target = cands_for_import[0][0]
                    
            # Scenario C: Globally unique match
            if not resolved_target and len(candidates) == 1:
                resolved_target = candidates[0][0]
                
            # Scenario D: Multiple matches: draw edges to all possible paths to ensure blast-radius stability
            if not resolved_target and len(candidates) > 1:
                for cand_id, _, _ in candidates:
                    edges_to_insert.append((caller_id, cand_id, 'calls'))
                continue
                
            if resolved_target:
                edges_to_insert.append((caller_id, resolved_target, 'calls'))
                
    for s, t, et in edges_to_insert:
        try: cursor.execute("INSERT OR IGNORE INTO edges VALUES (?, ?, ?)", (s, t, et))
        except: pass
    conn.commit()

# --- ASCII TREE BUILDER ---
def compile_ascii_tree(target_dir: str) -> str:
    files_to_check = []
    for file in sorted(os.listdir(target_dir)):
        path = os.path.join(target_dir, file)
        if os.path.isfile(path): files_to_check.append(("", file, path))
    modules_path = os.path.join(target_dir, "modules")
    if os.path.isdir(modules_path):
        for file in sorted(os.listdir(modules_path)):
            path = os.path.join(modules_path, file)
            if os.path.isfile(path): files_to_check.append(("modules", file, path))
    if not files_to_check: return ""
    lines = ["# Codebase Modules & Active Architecture:"]
    total = len(files_to_check)
    for idx, (subdir, name, path) in enumerate(files_to_check):
        display_name = os.path.join(subdir, name) if subdir else name
        desc = extract_file_description(path)
        connector = "└── " if idx == total - 1 else "├── "
        lines.append(f"#   {connector}{display_name:<24} - {desc}" if desc else f"#   {connector}{display_name}")
    return "\n".join(lines) + "\n# -----------------------------------------------------------------------------------------\n"

# --- COMPRESSED SHORTHAND COMPILER ---
def compile_flat_shorthand(skeleton):
    lines = []
    for rel_path, data in sorted(skeleton.items()):
        t = data.get("type", "file")
        if t == "python":
            imp = f"imp:{','.join(data.get('imports', []))}" if data.get('imports') else ""
            cls = f"cls:{','.join(data.get('classes', []))}" if data.get('classes') else ""
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            meta = " | ".join(filter(None, [imp, cls, fn]))
            lines.append(f"[py:{rel_path}] {meta}" if meta else f"[py:{rel_path}]")
        elif t == "markdown":
            title = f"title:{data.get('title', '')}" if data.get('title') else ""
            tags = f"tags:{','.join(data.get('tags', []))}" if data.get('tags') else ""
            links = f"links:{','.join(data.get('links', []))}" if data.get('links') else ""
            meta = " | ".join(filter(None, [title, tags, links]))
            lines.append(f"[md:{rel_path}] {meta}" if meta else f"[md:{rel_path}]")
        elif t.startswith("image/"):
            dim = f"dim:{data.get('dim', '')}" if data.get('dim') else ""
            sz = f"size:{data.get('size', '')}" if data.get('size') else ""
            meta = " | ".join(filter(None, [dim, sz]))
            lines.append(f"[{t}:{rel_path}] {meta}" if meta else f"[{t}:{rel_path}]")
        elif t in ("rust", "go", "qml"):
            cls = f"cls:{','.join(data.get('classes', []))}" if data.get('classes') else ""
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            meta = " | ".join(filter(None, [cls, fn]))
            lines.append(f"[{t}:{rel_path}] {meta}" if meta else f"[{t}:{rel_path}]")
        elif t == "lua":
            fn = f"fn:{','.join(data.get('functions', []))}" if data.get('functions') else ""
            lines.append(f"[{t}:{rel_path}] {fn}" if fn else f"[{t}:{rel_path}]")
        elif t == "json":
            keys = f"keys:{','.join(data.get('keys', []))}" if data.get('keys') else ""
            lines.append(f"[{t}:{rel_path}] {keys}" if keys else f"[{t}:{rel_path}]")
        else:
            summary = data.get("summary", "").replace("\n", " ").strip()
            lines.append(f"[{t}:{rel_path}] sum:{summary}" if summary else f"[{t}:{rel_path}]")
    return "\n".join(lines)

# --- CORE INDEXER ---
def run_indexing(target_dir, force=False):
    is_interactive = sys.stdin.isatty() and sys.stderr.isatty()
    if is_interactive and not force:
        try:
            sys.stderr.write(f"\033[2m[sys] Compile index map memory for \033[1;36m{os.path.basename(target_dir)}\033[0;2m? [↵ run  Esc]: \033[0m")
            sys.stderr.flush()
            key = get_key()
            if key in ('\x03', '\x1b', 'n', 'N'):
                sys.stderr.write("\r\x1b[K\033[2;31m[sys] Bypassed mapping execution.\033[0m\n")
                sys.stderr.flush(); safe_exit(0)
            sys.stderr.write("\r\x1b[K"); sys.stderr.flush()
        except: pass

    if target_dir == os.path.expanduser("~"):
        try:
            sys.stderr.write("\n\033[1;33m[sys] Warning: Scanning entire Home Directory. Proceed? (y/N): \033[0m"); sys.stderr.flush()
            if sys.stdin.readline().strip().lower() not in ['y', 'yes']: safe_exit(0)
        except: safe_exit(0)

    sys.stderr.write("ℹ Compiling relational index graph...\n"); sys.stderr.flush()
    
    proj_name = os.path.basename(target_dir)
    db_path = os.path.join(target_dir, f"index-map-memory-{proj_name}.db")
    db_conn = init_db(db_path)
    
    default_ignored = {
        '.git', '__pycache__', 'logs', '.auto-f', 'node_modules', 
        'venv', '.venv', 'SSD_BACKUPS', '.cargo', '.rustup', 
        '.cache', '.npm', '.local', '.mozilla', 'target'
    }
    patterns = load_gitignore_patterns(target_dir)
    
    skeleton = {}
    raw_calls = {}
    file_imports = {}
    
    file_count = 0
    for root, dirs, files in os.walk(target_dir):
        dirs[:] = [d for d in dirs if not should_ignore(os.path.relpath(os.path.join(root, d), target_dir), True, patterns, default_ignored)]
        for file in files:
            filepath = os.path.join(root, file)
            rel_path = os.path.relpath(filepath, target_dir)
