            sys.stdout.write(f"\033[{MENU_ROW};1H\033[K {status_message}")
            status_message = ""
        else:
            link_action = "  |  \033[1;36m[o]\033[0m Launch Links" if unique_links else ""
            sys.stdout.write(
                f"\033[{MENU_ROW};1H\033[K \033[1;36m[↑/↓]\033[0m Scroll  |  \033[1;36m[y / Ctrl+A]\033[0m Copy All  |  \033[1;36m[/]\033[0m Scanner Filter  |  \033[1;36m[n]\033[0m New Study{link_action}  |  \033[1;33m[q]\033[0m Exit"
            )
        sys.stdout.flush()
        
        key = get_key()
        if key == '\033[A':
            if scroll_offset > 0:
                scroll_offset -= 1
        elif key == '\033[B':
            if scroll_offset + VISIBLE_ROWS < len(body_lines):
                scroll_offset += 1
        elif key == '/':
            search_query = get_text_input("Enter scanner keyword to highlight: ")
        elif key.lower() == 'o' and unique_links:
            run_link_menu(unique_links)
        elif key.lower() == 'n':
            return "new"
        elif key == '\x01' or key.lower() == 'y':  # '\x01' is Ctrl+A
            if copy_to_clipboard(report_text):
                status_message = f"{GREEN}✓ Copied entire report to clipboard successfully!{RESET}"
            else:
                status_message = f"{YELLOW}⚠️ No clipboard backend found (requires wl-copy, xclip, or xsel).{RESET}"
        elif key.lower() == 'q' or key == '\r':
            return "exit"

# --- Main Runtime ---

def main():
    sys.stdout.write("\033[?1049h\033[H\033[?25l")
    sys.stdout.flush()
    
    try:
        topic = " ".join(sys.argv[1:]) if len(sys.argv) > 1 else ""
        
        while True:
            if not topic:
                print_header("Analysis Portal")
                print(" Enter a subject to coordinate a deep multi-round search:\n")
                user_query = get_text_input("Research Subject: ")
                if not user_query:
                    break
                topic = user_query
                
            result = run_research_pipeline(topic)
            if not result:
                print_header("API Verification Fault")
                print("\033[1;31m⚠️ Research pipeline was aborted.\033[0m")
                print(" Check that you have configured your GEMINI_API_KEY environment credentials.")
                print("\n Press any key to retry.")
                get_key()
                topic = ""
                continue
                
            report_text, category = result
            action = render_report_viewer(topic, report_text, category)
            
            if action == "new":
                topic = ""
            else:
                break
    finally:
        sys.stdout.write("\033[?1049l\033[?25h")
        sys.stdout.flush()

if __name__ == "__main__":
    main()
