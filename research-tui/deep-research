def run_research_pipeline(topic):
    # Call the bridge script from your research-tui folder
    bridge_path = "/home/j5/.config/local-ai/research-tui/odysseus-cli"
    try:
        # We pass the topic as a single argument
        result = subprocess.run(
            [bridge_path, topic], 
            capture_output=True, text=True, check=True
        )
        return result.stdout, "general"
    except subprocess.CalledProcessError as e:
        return None, None

    # plan strategy
    log("Analyzing research goal and mapping plan...")
    plan_prompt = current_date_context() + (
        f"You are a research strategist. Analyze this request and generate a structured research plan:\n\n"
        f"Question: {topic}\n\n"
        f"Respond with a JSON object containing exactly:\n"
        f"- \"sub_questions\": List of 3-4 specific elements to verify\n"
        f"- \"key_topics\": Key aspects to analyze\n"
        f"- \"success_criteria\": Definition of a complete answer\n"
    )
    raw_plan_response = query_gemini(plan_prompt)
    plan_data = extract_json_object(raw_plan_response)
    
    if plan_data:
        plan_desc = f"Sub-questions: " + "; ".join(plan_data.get("sub_questions", []))
        log(f"Plan constructed: \033[1;32m{plan_data.get('success_criteria', 'Success Criteria Mapped')}\033[0m")
    else:
        plan_desc = "Analyze specifications, parameters, and system requirements dynamically."
        log("Proceeding with standard broad-search plan...")

    # Classify Category
    log("Classifying research category schema...")
    raw_cat = query_gemini(
        f"Classify this research topic into exactly one category: [product, comparison, howto, factcheck, general]. Topic: '{topic}'. Reply with ONLY the lowercase category name."
    ).strip().lower()
    category = re.sub(r'[^a-z]', '', raw_cat)
    if category not in ["product", "comparison", "howto", "factcheck", "general"]:
        category = "general"
    log(f"Categorization mapped: \033[1;36m{category.upper()}\033[0m")

    # Initialize Planning (Using Odysseus Deconstruction logic)
    log("Formulating discovery search queries...")
    planning_prompt = current_date_context() + (
        f"Original question: {topic}\n"
        f"Research plan: {plan_desc}\n\n"
        f"Generate exactly 2 diverse search queries to collect initial facts.\n"
        f"CRITICAL RULES:\n"
        f"1. If the topic compares multiple options/models (e.g. 'A vs B' or 'A compared to B'), "
        f"DO NOT combine them into a single search string. Instead, generate Query 1 targeting ONLY Entity A, "
        f"and Query 2 targeting ONLY Entity B.\n"
        f"2. Focus queries on specific technical specifications, parameters, and documentation indices.\n"
        f"Respond ONLY with a JSON array, e.g. [\"query1\", \"query2\"]."
    )
    raw_planning = query_gemini(planning_prompt)
    queries = extract_json_array(raw_planning)
    
    if not queries or not isinstance(queries, list):
        lines = [line.strip().strip('"\'-,•*') for line in raw_planning.splitlines() if line.strip()]
        queries = [l for l in lines if len(l) > 2][:2]
        if not queries:
            queries = [f"{topic} latest updates", f"{topic} overview"]
    else:
        queries = [str(q).strip() for q in queries[:2]]

    log(f"Formulated targets: {', '.join([f'\"{q}\"' for q in queries])}")

    evolving_report, max_rounds, current_round = "", 3, 1
    crawl_url = None
    total_findings_gathered = 0
    
    # Step 3: Iterative Crawl & Integration Loop
    while current_round <= max_rounds:
        log(f"Initiating analysis round {current_round}/{max_rounds}...")
        
        # Concurrently search queries and crawl secondary link sources in parallel
        findings = execute_concurrent_requests(queries, crawl_url)
        time.sleep(0.5)

        # Failsafe Check: If direct searches are blank, attempt broad fallbacks
        if not findings or all(not f for f in findings):
            log("No direct search results. Executing broad backup queries...")
            backup_queries = [
                f"{topic.replace('vs.', ' ').replace('vs', ' ')} specifications",
                f"{queries[0]} wiki" if queries else f"{topic} model parameters"
            ]
            findings = execute_concurrent_requests(backup_queries)

        if findings and any(f for f in findings):
            total_findings_gathered += len([f for f in findings if f])

        log("Synthesizing metrics and auditing missing details...")
        synthesis_prompt = current_date_context() + (
            f"You are updating an evolving research report.\n"
            f"Original question: {topic}\n"
            f"Evolving report:\n{evolving_report or '(First round — no report yet.)'}\n\n"
            f"New Findings:\n{chr(10).join(findings)}\n\n"
            "Integrate these new findings into the report. Keep source URLs inline as citations.\n"
            "At the VERY bottom of your response, output a status block with these exact markers:\n"
            "STOP: [YES or NO] (Write YES if the topic is covered comprehensively, or NO if critical facts are still missing)\n"
            "QUERY: [Next search query] (If STOP is NO, write exactly 1 surgical search query to target the missing facts)\n"
            "CRAWL: [Optional URL] (If STOP is NO, extract exactly 1 high-priority reference page URL found inside the new findings to scrape deeply, otherwise leave blank)"
        )
        response = query_gemini(synthesis_prompt)
        
        parts = re.split(r"(?i)\bstop\s*:\s*", response, maxsplit=1)
        evolving_report = parts[0].strip()
        stop_section = parts[1].strip() if len(parts) > 1 else ""

        should_stop = "YES" in stop_section.upper()
        if should_stop:
            log("Report convergence criteria met. Halting iterations.")
            break
        elif current_round == max_rounds:
            log("Final round limit reached. Compiling findings.")
            break

        # Parse next search query and crawling targets
        query_match = re.search(r"QUERY:\s*(.*)", stop_section, re.IGNORECASE)
        crawl_match = re.search(r"CRAWL:\s*(https?://[^\s)\]]+)", stop_section, re.IGNORECASE)
        
        raw_next_query = query_match.group(1).strip() if query_match else ""
        raw_next_query = re.sub(r"(?i)\s*CRAWL\s*:.*", "", raw_next_query).strip().strip('"\'')
        
        queries = [raw_next_query] if raw_next_query else [f"{topic} missing details"]
        crawl_url = crawl_match.group(1).strip() if crawl_match else None
        
        if crawl_url:
            log(f"Gap found. Planning: \"{queries[0]}\" & crawling target: \"{crawl_url}\"")
        else:
            log(f"Gap found. Directing query: \"{queries[0]}\"")
            
        current_round += 1

    # --- Odysseus Design Pattern 5: Core Web Search Failsafe ---
    if total_findings_gathered == 0:
        log("\033[1;31m⚠️ Failure: Web search returned 0 results. Aborting to prevent hallucination.\033[0m")
        time.sleep(2.0)
        report_text = (
            "ERROR: SYSTEM DATA RETRIEVAL FAILURE\n\n"
            "The deep research agent was unable to retrieve any web search results for this topic. "
            "This is typically caused by temporary search provider blocks, active rate limits, or network timeouts.\n\n"
            "To maintain strict factual safety and prevent model hallucination, compilation has been aborted. "
            "Please check your network settings, verify that your search backends are active, or try again later."
        )
        return report_text, "general"

    # Step 4: Formatting Refinement & Citation Index
    log("Structuring output and organizing references...")
    category_prompts = {
        "product": "Structure as a RANKED list of options (best first). Include price, pros, cons, and links. End with a Verdict section.",
        "comparison": "Create a Comparison Table in markdown comparing all options. Outline individual strengths and weaknesses.",
        "howto": "Start with a Quick Guide (one line per step). List prerequisites. Outline detailed steps. End with Common Mistakes.",
        "factcheck": "State the Claim. Provide Evidence For and Evidence Against. Conclude with a Verdict (Supported, Mixed, Unsupported).",
        "general": "Provide an Executive Summary, Detailed Findings, and a final conclusion."
    }

    final_prompt = current_date_context() + (
        f"You are a senior analyst. Refine this compiled research report on '{topic}':\n\n"
        f"{evolving_report}\n\n"
        f"Formatting requirement: {category_prompts[category]}\n\n"
        "At the bottom of the report, compile a distinct SOURCES AND CITATIONS section containing an organized, numbered list of all unique source URLs discovered during the research. Ensure all URLs are clean and readable.\n\n"
        "Format your output strictly for clean, plain-text terminal rendering. DO NOT use any Markdown formatting (such as ### headers, ** bolding, or * asterisks). Use simple capitalized headers and clean vertical line spaces for emphasis."
    )
    
    raw_final_report = query_gemini(final_prompt)
    
    # Word-Count Auto-Expansion Loop (Odysseus Pattern 4)
    word_count = len(raw_final_report.split())
    if word_count < 400:
        log(f"Initial compile is brief ({word_count} words). Launching auto-expansion...")
        expanded_prompt = (
            f"This report is too brief. Please expand it significantly:\n"
            f"- Add detailed paragraphs for each section (not just bullet points)\n"
            f"- Include specific data, numbers, and comparisons from the evidence\n"
            f"- Explain context and significance — don't just list facts\n"
            f"- Use capitalized headings and clean vertical spacing (no markdown bolding/asterisks)\n"
            f"Write the full expanded report now."
        )
        expanded_report = query_gemini_chat([
            {"role": "user", "content": final_prompt},
            {"role": "assistant", "content": raw_final_report},
            {"role": "user", "content": expanded_prompt}
        ])
        if len(expanded_report.split()) > word_count:
            raw_final_report = expanded_report

    clean_final_report = re.sub(r'\*\*(.*?)\*\*', r'\1', raw_final_report)
    clean_final_report = re.sub(r'\*(.*?)\*', r'\1', clean_final_report)
    
    log("Report built successfully. Displaying portal.")
    time.sleep(0.5)
    return clean_final_report, category

