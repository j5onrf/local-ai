import logging
import openai
from typing import List, Dict, Any

# Configure logging to monitor routing transitions in real time
logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(levelname)s - %(smsg)s')
logger = logging.getLogger("AgentRouter")

class FailoverLLMClient:
    def __init__(self, providers: List[Dict[str, Any]]):
        """
        Initializes the router with an ordered fallback chain of providers.
        Each provider item should look like this:
        {
            "name": "Groq",
            "base_url": "https://api.groq.com/openai/v1",
            "api_key": "gsk_...",
            "model": "llama3-8b-8192"
        }
        """
        self.providers = providers

    def chat_completion(self, messages: List[Dict[str, str]], **kwargs) -> Any:
        """
        Iterates through providers sequentially until a successful completion is returned.
        Automatically switches providers on rate limits, connection failures, or server errors.
        """
        for provider in self.providers:
            logger.info(f"Attempting request using: {provider['name']} (Model: {provider['model']})")
            
            try:
                # Instantiating a clean client instance for the specific target endpoint
                client = openai.OpenAI(
                    base_url=provider.get("base_url"),
                    api_key=provider.get("api_key")
                )
                
                # Combine global parameters with provider-specific parameters
                request_params = {**kwargs, "model": provider["model"], "messages": messages}
                
                # Execute the completion
                response = client.chat.completions.create(**request_params)
                logger.info(f"Successfully received response from {provider['name']}.")
                return response
                
            except openai.RateLimitError as e:
                logger.warning(f"Rate limit (429) hit for {provider['name']}: {e}. Falling over...")
                continue
            except openai.InternalServerError as e:
                logger.warning(f"Server error (5xx) on {provider['name']}: {e}. Falling over...")
                continue
            except openai.APIConnectionError as e:
                logger.warning(f"Network connection failed for {provider['name']}: {e}. Falling over...")
                continue
            except openai.APIError as e:
                logger.error(f"General API error with {provider['name']}: {e}. Skipping...")
                continue
            except Exception as e:
                logger.error(f"Unexpected error with {provider['name']}: {e}. Skipping...")
                continue
                
        # If the loop completes without returning, all backends failed
        raise RuntimeError("All configured LLM providers failed or exhausted their limits.")
