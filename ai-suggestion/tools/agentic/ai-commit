#!/usr/bin/env bash
# ai-commit - Automate Git Commits with AI Context v1.0.3

set -euo pipefail

# Check if there are any staged changes
if [[ -z "$(git diff --cached)" ]]; then
    echo "❌ Error: No staged changes found. Run 'git add' first." >&2
    exit 1
fi

# Define paths to bypass interactive subshell function limits
_AI_SCRIPT_PATH="$HOME/.config/local-ai/ai-suggestion/alias-ai.py"
_AI_PYTHON_BIN=$(command -v python3 2>/dev/null || type -p python3 2>/dev/null || echo "python3")

# Query the Python script directly to generate the message
message=$("$_AI_PYTHON_BIN" "$_AI_SCRIPT_PATH" --talk "Write a single, precise, plain-text git commit message (max 10 words, no markdown, no quotes) describing these staged changes: $(git diff --cached)")

# Clean up any trailing quotes or spaces
message=$(echo "$message" | tr -d '"' | xargs)

# Execute the commit
git commit -m "$message"
