#!/usr/bin/env python3
# chat - Unified Agentic Brainstorm, Thinking & Follow-up Engine

import sys
import os
import json
import re
import urllib.request as urlreq

try:
    import agent_ui as ui
except ImportError:
    ui = None

CFG_DIR = os.path.expanduser("~/.config/local-ai")

try:
    history = json.loads(sys.stdin.read())
except Exception:
    sys.stderr.write("Error: No valid chat history passed to brainstorm tool.\n")
    sys.exit(1)

query_string = " ".join(sys.argv[1:]).lower().strip()
cmd_match = re.match(r'^/?([ftba])(?:\s+(\d+))?$', query_string)

cmd_char = cmd_match.group(1) if cmd_match else "f"
option_count = int(cmd_match.group(2)) if (cmd_match and cmd_match.group(2) and 1 <= int(cmd_match.group(2)) <= 10) else 3

is_brain_cmd, is_think_cmd, is_all_cmd = (cmd_char == "b"), (cmd_char == "t"), (cmd_char == "a")

if is_brain_cmd:
    skill_file, output_header, fallback_term = "brainstorm.md", "Brainstorm", "brainstorm"
elif is_think_cmd:
    skill_file, output_header, fallback_term = "thinking.md", "Thinking", "think"
elif is_all_cmd:
    skill_file, output_header, fallback_term = "all", "Follow-up", "all"
else:
    skill_file, output_header, fallback_term = "follow-up.md", "Follow-up", "follow-up"

THINK_FILE = f"{CFG_DIR}/skills/meta/{skill_file}"

prompt = ""
if is_all_cmd:
    prompts = {}
    for f_name, header in [("follow-up.md", "Follow-up"), ("thinking.md", "Thinking"), ("brainstorm.md", "Brainstorm")]:
        path = f"{CFG_DIR}/skills/meta/{f_name}"
        if os.path.exists(path):
            try:
                content = open(path, "r", encoding="utf-8").read().strip()
                prompts[header] = content.split("Template:")[0].strip() if "Template:" in content else content
            except Exception:
                pass

    if prompts:
        prompt = (
            "Analyze the preceding conversation history and output exactly three sections: Follow-up, Thinking, and Brainstorm.\n"
            "You must output ONLY these three sections, with no conversational introductions or explanations.\n\n"
            "Template (Ensure headers are exact, flush left, with no empty lines between options):\n"
            "Follow-up\n[Option 1]\n[Option 2]\n[Option 3]\n"
            "Thinking\n[Option 1]\n[Option 2]\n[Option 3]\n"
            "Brainstorm\n[Option 1]\n[Option 2]\n[Option 3]\n\n"
            "Strictly adhere to the specific guidelines for each section detailed below:\n"
            f"<FOLLOW_UP_RULES>\n{prompts.get('Follow-up', '')}\n</FOLLOW_UP_RULES>\n\n"
            f"<THINKING_RULES>\n{prompts.get('Thinking', '')}\n</THINKING_RULES>\n\n"
            f"<BRAINSTORM_RULES>\n{prompts.get('Brainstorm', '')}\n</BRAINSTORM_RULES>"
        )
elif os.path.exists(THINK_FILE):
    try:
        prompt = open(THINK_FILE, "r", encoding="utf-8").read().strip()
    except Exception:
        pass

if not prompt:
    if is_all_cmd:
        prompt = (
            "Analyze history and output exactly three sections: Follow-up, Thinking, and Brainstorm.\n"
            "Each section must have exactly 3 options, each strictly 6 to 10 words long.\n"
            "No conversational filler. Output exactly this format:\n\n"
            "Follow-up\n[Option 1]\n[Option 2]\n[Option 3]\n"
            "Thinking\n[Option 1]\n[Option 2]\n[Option 3]\n"
            "Brainstorm\n[Option 1]\n[Option 2]\n[Option 3]"
        )
    else:
        prompt = (
            f"Analyze history and output exactly 3 next-step {fallback_term} items.\n"
            "Each option must be strictly 6 to 10 words long.\n"
            "No conversational filler. Output exactly this format:\n\n"
            f"{output_header}\n[Option 1]\n[Option 2]\n[Option 3]"
        )
else:
    prompt = prompt.replace("exactly 3", f"exactly {option_count}")

instruction_block = (
    "[COMMAND: Do not continue the conversation. Do not reply to the last message. "
    "Instead, execute this specific analytical directive based on our preceding chat history immediately. "
    "Do not include any chatty conversational introductions or preambles.]\n\n"
    f"{prompt}"
)
history.append({"role": "user", "content": instruction_block})

configs = []
gkey, okey = os.environ.get("GEMINI_API_KEY"), os.environ.get("OPENROUTER_API_KEY")

if gkey:
    configs.append((
        "https://generativelanguage.googleapis.com/v1beta/openai/chat/completions",
        {"Authorization": f"Bearer {gkey}"},
        os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite"),
        {}, 10
    ))
if okey:
    configs.append((
        "https://openrouter.ai/api/v1/chat/completions",
        {"Authorization": f"Bearer {okey}", "HTTP-Referer": "https://github.com/j5onrf/local-ai"},
        os.environ.get("OPENROUTER_MODEL", "openrouter/free"),
        {}, 10
    ))

configs.append(("http://localhost:8080/v1/chat/completions", {}, None, {"chat_template_kwargs": {"enable_thinking": False}}, 180))

for url, headers, model, extra, timeout in configs:
    body = {"messages": history, "stream": True, **extra}
    if model:
        body["model"] = model
    req = urlreq.Request(url, data=json.dumps(body).encode("utf-8"), headers={"Content-Type": "application/json", **headers}, method="POST")
    spinner = None
    try:
        if ui and sys.stdout.isatty():
            spinner = ui.InlineSpinner()
            spinner.start()

        with urlreq.urlopen(req, timeout=timeout) as response:
            first_token, chunks = True, []
            for line in response:
                dec = line.decode("utf-8", errors="ignore").strip()
                if not dec or dec == "[DONE]":
                    continue
                if dec.startswith("data:"):
                    dec = dec[5:].strip()
                try:
                    data = json.loads(dec)
                    content = ""
                    if "choices" in data and data["choices"]:
                        content = data["choices"][0].get("delta", {}).get("content", "")
                    elif "candidates" in data and data["candidates"]:
                        content = data["candidates"][0].get("content", {}).get("parts", [{}])[0].get("text", "")
                    if content:
                        if first_token:
                            if spinner:
                                spinner.stop()
                                spinner = None
                            content = content.lstrip()
                            if not content:
                                continue
                            first_token = False
                        chunks.append(content)
                except Exception:
                    pass
            
            if spinner:
                spinner.stop()
                spinner = None

            full_text = "".join(chunks).strip()
            lines = [l.strip() for l in full_text.splitlines() if l.strip()]
            if lines:
                headers_map = {
                    "follow-up": "Follow-up", "follow-ups": "Follow-up",
                    "thinking": "Thinking", "think": "Thinking",
                    "brainstorm": "Brainstorm", "brainstorming": "Brainstorm"
                }
                
                sys.stdout.write("\n")
                first_line_clean = lines[0].lower().rstrip('s:')
                
                start_index = 0
                if first_line_clean not in headers_map:
                    for idx, line in enumerate(lines):
                        if line.lower().rstrip('s:') in headers_map:
                            start_index = idx
                            break
                    else:
                        sys.stdout.write(f"\033[1;32mAI:\033[0m {output_header}\n")
                
                for line in lines[start_index:]:
                    clean_line = line.lower().rstrip('s:')
                    if clean_line in headers_map:
                        sys.stdout.write(f"\033[1;32mAI:\033[0m {headers_map[clean_line]}\n")
                    else:
                        sys.stdout.write(f"{line}\n")
                sys.stdout.flush()
            sys.exit(0)
    except KeyboardInterrupt:
        if spinner:
            spinner.stop()
        sys.stderr.write("\n\033[90m[sys] Interrupted.\033[0m\n")
        sys.exit(130)
    except Exception:
        if spinner:
            spinner.stop()
            spinner = None
        pass

sys.stderr.write("Error: All brainstorm service fallbacks are offline.\n")
sys.exit(1)
