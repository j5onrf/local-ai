try:
    import agent_core as context
    get_key = context.get_key
except ImportError:
    context = None
    def get_key() -> str:
        tty_file = None
        try:
            tty_file = open("/dev/tty", "r+")
            fd = tty_file.fileno()
        except Exception:
            fd = sys.stdin.fileno()
        try:
            import fcntl
            flags = fcntl.fcntl(fd, fcntl.F_GETFL)
            fcntl.fcntl(fd, fcntl.F_SETFL, flags & ~os.O_NONBLOCK)
        except Exception: pass
        try:
            old = termios.tcgetattr(fd)
        except Exception:
            try: return os.read(fd, 1).decode("utf-8", errors="ignore")
            except Exception: return ""
            finally:
                if tty_file: tty_file.close()
        try:
            tty.setraw(fd)
            try: termios.tcflush(fd, termios.TCIFLUSH)
            except Exception: pass
            b = os.read(fd, 1)
            if b == b'\x1b' and select.select([fd], [], [], 0.05)[0]:
                b += os.read(fd, 2)
            return b.decode("utf-8", errors="ignore")
        except Exception: return ""
        finally:
            termios.tcsetattr(fd, termios.TCSADRAIN, old)
            if tty_file: tty_file.close()


def print_session_box(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    turns, checkpoints = 0, 0
    if os.path.exists(db_path):
        try:
            with closing(sqlite3.connect(db_path, timeout=10)) as conn:
                cur = conn.cursor()
                cur.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
                turns = cur.fetchone()[0]
                cur.execute("SELECT COUNT(*) FROM checkpoints WHERE workspace = ?", (workspace,))
                checkpoints = cur.fetchone()[0]
        except Exception: pass
    home_dir = os.path.expanduser("~")
    ws_path = os.environ.get("AI_WORKSPACE_PATH") or (os.path.join(home_dir, workspace.replace("-", "/")) if workspace.startswith(".config") else workspace.replace("-", "/"))
    disp = ws_path.replace(home_dir, "~", 1) if ws_path.startswith(home_dir) else ws_path
    if len(disp) > 28: disp = "..." + disp[-25:]
    model = os.environ.get("CLOUD_MODEL", "gemini-3.1-flash-lite") if os.environ.get("GEMINI_API_KEY") else os.environ.get("OPENROUTER_MODEL", "openrouter/free") if os.environ.get("OPENROUTER_API_KEY") else "local-model"
    skill = " ".join(s.lstrip("-") for s in os.environ.get("AI_ACTIVE_SKILL", "").split()) or "default"
    box_w = 46
    lines = [" >_ Local-AI Session Manager", "", f" model:     {model}", f" directory: {disp}", f" skill:     {skill}", f" database:  {turns} turns, {checkpoints} saves"]
    sys.stderr.write("\n\033[1;36m╭" + "─" * box_w + "╮\n\033[0m")
    for i, l in enumerate(lines):
        if i == 1:
            sys.stderr.write(f"\033[1;36m│\033[0m{' ':<{box_w}}\n\033[0m")
        else:
            style = "\033[1;37m" if i == 0 else "\033[2m"
            sys.stderr.write(f"\033[1;36m│\033[0m {style}{l:<{box_w-1}}\033[0m\033[1;36m│\n\033[0m")
    sys.stderr.write("\033[1;36m╰" + "─" * box_w + "╯\n\033[0m")
    sys.stderr.flush()


def init_db(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("CREATE TABLE IF NOT EXISTS checkpoints (id INTEGER PRIMARY KEY AUTOINCREMENT, workspace TEXT NOT NULL, tag TEXT NOT NULL, history TEXT NOT NULL, timestamp INTEGER NOT NULL)")
        cur.execute("CREATE TABLE IF NOT EXISTS turns (id INTEGER PRIMARY KEY AUTOINCREMENT, workspace TEXT NOT NULL, user_msg TEXT NOT NULL, assistant_msg TEXT NOT NULL, tokens TEXT NOT NULL, timestamp INTEGER NOT NULL)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_turns_workspace ON turns (workspace)")
        cur.execute("CREATE INDEX IF NOT EXISTS idx_checkpoints_workspace ON checkpoints (workspace)")
        conn.commit()


def save_checkpoint(workspace: str, tag: str) -> None:
    try:
        hist_data = sys.stdin.read().strip()
        json.loads(hist_data)
    except Exception:
        sys.stderr.write("\033[1;31m[session-mgr] Invalid history data received via stdin.\033[0m\n")
        sys.exit(1)
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("INSERT INTO checkpoints (workspace, tag, history, timestamp) VALUES (?, ?, ?, ?)", (workspace, tag, hist_data, int(time.time())))
        conn.commit()
    sys.stderr.write(f"\033[1;32m[session-mgr] Checkpoint '{tag}' saved to SQLite for '{workspace}'.\033[0m\n")


def rollback_checkpoint(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("SELECT tag, history, timestamp FROM checkpoints WHERE workspace = ? ORDER BY timestamp DESC", (workspace,))
        rows = cur.fetchall()
    print_session_box(workspace)
    if not rows:
        sys.stderr.write(f"\033[1;31m[session-mgr] No checkpoints found for: {workspace}\033[0m\n")
        sys.exit(0)
    sys.stderr.write("\n\033[1;36m--- Active Checkpoints (SQLite) ---\033[0m\n")
    for idx, (tag, history, ts) in enumerate(rows):
        try: turns_len = len(json.loads(history))
        except Exception: turns_len = 0
        date_str = time.strftime('%Y-%m-%d %H:%M:%S', time.localtime(ts))
        sys.stderr.write(f"[{idx}] \033[1;32m{tag}\033[0m ({turns_len} turns) - {date_str}\n")
    sys.stderr.write("\n\033[1;30mSelect index to restore, or press Esc/Ctrl+C to cancel:\033[0m\n\033[?25l")
    sys.stderr.flush()
    try:
        key = ""
        while True:
            if not key: key = get_key()
            if not key:
                sys.stderr.write("\033[?25h\033[1;30mSelect Index: \033[0m")
                sys.stderr.flush()
                try:
                    with open("/dev/tty", "r+", encoding="utf-8") as tty_in:
                        try:
                            import fcntl
                            flags = fcntl.fcntl(tty_in.fileno(), fcntl.F_GETFL)
                            fcntl.fcntl(tty_in.fileno(), fcntl.F_SETFL, flags & ~os.O_NONBLOCK)
                        except Exception: pass
                        key = tty_in.readline().strip()
                except KeyboardInterrupt: key = '\x1b'
                except Exception: key = ''
            if key in ('\x03', '\x1b', 'q', 'Q', ''):
                sys.stderr.write("\r\x1b[KCancelled.\n")
                sys.exit(0)
            if key.isdigit() and int(key) < len(rows):
                selected_tag, selected_history, _ = rows[int(key)]
                sys.stderr.write(f"\r\x1b[K\033[1;32m[session-mgr] Loading checkpoint '{selected_tag}'...\033[0m\n")
                print(selected_history)
                break
            else:
                sys.stderr.write(f"\r\x1b[K\033[1;31m[session-mgr] Invalid selection. Enter 0-{len(rows)-1} (or Esc to cancel): \033[0m")
                sys.stderr.flush()
                key = ""
    finally:
        sys.stderr.write("\033[?25h")
        sys.stderr.flush()


def log_turn(workspace: str, user_msg: str, assistant_msg: str) -> None:
    if "### Real-time System Context:" in user_msg:
        user_msg = user_msg.split("User Question:", 1)[-1].strip()
    tokens_str = " ".join(tokenize(user_msg))
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("INSERT INTO turns (workspace, user_msg, assistant_msg, tokens, timestamp) VALUES (?, ?, ?, ?, ?)", (workspace, user_msg, assistant_msg, tokens_str, int(time.time())))
        conn.commit()


def search_past_context(workspace: str, query: str) -> None:
    q_tokens = set(tokenize(query))
    if not q_tokens: return
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    with closing(sqlite3.connect(db_path, timeout=10)) as conn:
        cur = conn.cursor()
        cur.execute("SELECT user_msg, assistant_msg, tokens, timestamp FROM turns WHERE workspace = ?", (workspace,))
        rows = cur.fetchall()
    candidates = []
    for user_msg, assistant_msg, tokens, ts in rows:
        t_tokens = set(tokens.split())
        score = len(q_tokens & t_tokens) / len(q_tokens | t_tokens) if (q_tokens & t_tokens) else 0.0
        if score >= 0.35:
            candidates.append((score, user_msg, assistant_msg, ts))
    if not candidates: return
    candidates.sort(key=lambda x: -x[0])
    num_opts, current_idx = len(candidates), 0
    sys.stderr.write("\033[?25l")
    sys.stderr.flush()
    try:
        while True:
            _, user_msg, assistant_msg, ts = candidates[current_idx]
            idx_str = f"[{current_idx + 1:02d}/{num_opts:02d}] ❯ " if num_opts > 1 else ""
            disp = user_msg.strip().replace("\n", " ")
            if len(disp) > 40: disp = disp[:47] + "..."
            date_str = time.strftime('%Y-%m-%d %H:%M', time.localtime(ts))
            sys.stderr.write(f"\r\x1b[K\033[2m{idx_str}[memory] ({date_str})\033[0m\n\r\x1b[K\033[3m   \"{disp}\"\033[0m [↵ load  d: disable  Esc/Arrows: skip]: ")
            sys.stderr.flush()
            key = get_key()
            sys.stderr.write("\r\x1b[K\x1b[1A\r\x1b[K")
            sys.stderr.flush()
            if key == '\x03':
                sys.stderr.write("Cancelled.\n")
                sys.exit(2)
            elif key in ('\r', '\n', ''):
                sys.stderr.write("\033[2;32m[sys] Memory injected.\033[0m\n")
                sys.stderr.flush()
                print("\n### Relevant Past Discussion (Retrieved from Session Memory):")
                print(f"* **On {date_str} you asked**: \"{user_msg}\"\n  **Agent responded**: \"{assistant_msg.strip()}\"")
                break
            elif key in ('d', 'D'):
                sys.stderr.write("\033[2;31m[sys] Memory recall disabled. (Type /m to re-enable)\033[0m\n")
                sys.stderr.flush()
                sys.exit(3)
            elif key in ('\x1b[A', '\x1b[B'):
                current_idx = (current_idx + (1 if key == '\x1b[B' else -1) + num_opts) % num_opts
            else:
                sys.stderr.write("\033[2;31m[sys] Memory recall skipped.\033[0m\n")
                sys.stderr.flush()
                sys.exit(0)
    finally:
        sys.stderr.write("\033[?25h")
        sys.stderr.flush()


def get_turns_count(workspace: str) -> None:
    db_path = os.path.join(SESSIONS_DIR, f"{workspace}.db")
    if os.path.exists(db_path):
        with closing(sqlite3.connect(db_path, timeout=10)) as conn:
            cur = conn.cursor()
            cur.execute("SELECT COUNT(*) FROM turns WHERE workspace = ?", (workspace,))
            print(cur.fetchone()[0])
    else:
        print(0)


